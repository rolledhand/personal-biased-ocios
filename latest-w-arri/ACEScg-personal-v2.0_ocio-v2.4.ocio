          saturation: 0.86
        - !<GradingToneTransform>
          style: log
          blacks: {rgb: [1, 1, 1], master: 0.950, start: 0.32, width: 0.50}
          highlights: {rgb: [1, 1, 1], master: 0.972, start: 0.27, pivot: 0.88}
          whites: {rgb: [1, 1, 1], master: 0.988, start: 0.34, width: 0.50}
          s_contrast: 1.00
        - !<CDLTransform> {slope: [1.010, 1.010, 1.010], offset: [0.000, 0.000, 0.000], power: [0.990, 0.990, 0.990], sat: 1.01}
