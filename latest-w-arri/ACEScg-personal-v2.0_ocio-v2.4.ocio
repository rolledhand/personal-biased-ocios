displays:
  sRGB - Display:
    - !<View> {name: Raw, colorspace: Raw}
    - !<Views> [ACES 2.0 - SDR 100 nits (Rec.709), ACES 2.0 - SDR 100 nits (Rec.709) - Editorial Split, ACES 2.0 - SDR 100 nits (Rec.709) - Graphite Matte, ACES 2.0 - SDR 100 nits (Rec.709) - Cold Steel Neutral, ACES 2.0 - SDR 100 nits (Rec.709) - Carbon Black, ACES 2.0 - SDR 100 nits (Rec.709) - Carbon Plate, ACES 2.0 - SDR 100 nits (Rec.709) - Archival Warm-Gray, ACES 2.0 - SDR 100 nits (Rec.709) - Film Dense, ACES 2.0 - SDR 100 nits (Rec.709) - Photochemical, ACES 2.0 - SDR 100 nits (Rec.709) - Vitrine, ACES 2.0 - SDR 100 nits (Rec.709) - Chemical Drift, ACES 2.0 - SDR 100 nits (Rec.709) - Phoenix Drift, ACES 2.0 - SDR 100 nits (Rec.709) - Tarnished Print, ACES 2.0 - SDR 100 nits (Rec.709) - Negative Dust, ACES 2.0 - SDR 100 nits (Rec.709) - Archival Extreme Matte, ACES 2.0 - SDR 100 nits (Rec.709) - Soot, ACES 2.0 - SDR 100 nits (Rec.709) - Blue Carbon Print, ACES 2.0 - SDR 100 nits (Rec.709) - Funeral Bronze, ACES 2.0 - SDR 100 nits (Rec.709) - Verdigris Shadow]
