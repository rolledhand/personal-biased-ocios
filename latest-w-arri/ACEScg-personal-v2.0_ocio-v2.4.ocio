ocio_profile_version: 2.4
environment:
  {}
search_path: ""
strictparsing: true
luma: [0.2126, 0.7152, 0.0722]
name: cg-config-v3.0.0_aces-v2.0_ocio-v2.4
description: |
  Academy Color Encoding System - CG Config [COLORSPACES v3.0.0] [ACES v2.0] [OCIO v2.4]
  --------------------------------------------------------------------------------------
  This minimalistic "OpenColorIO" config is geared toward computer graphics artists requiring a lean config that does not include camera colorspaces and the less common displays and looks.
roles:
  aces_interchange: ACES2065-1
  cie_xyz_d65_interchange: CIE XYZ-D65 - Display-referred

  data: Raw

  # Houdini personal render-space defaults
  default: ACEScg
  scene_linear: ACEScg
  rendering: ACEScg
  reference: ACES2065-1
  default_float: ACEScg

  # Byte/UI defaults
  default_byte: sRGB - Texture
  default_sequencer: sRGB - Texture
  color_picking: sRGB - Texture
  texture_paint: sRGB - Texture

  # Log / grading defaults
  matte_paint: ACEScct
  color_timing: ACEScct
  compositing_log: ACEScct
  compositing_linear: ACEScg

  # Useful app aliases
  srgb_linear: Linear Rec.709 (sRGB)
  
file_rules:
  # --------------------------------------------------------------------------
  # 01. Existing simple token/name rules
  # Keep these lightweight rules from the current ACEScg config.
  # --------------------------------------------------------------------------

  - !<Rule> {name: srgb_tx, colorspace: sRGB - Texture, pattern: "*srgb_tx*", extension: "*"}
  - !<Rule> {name: srgb_texture, colorspace: sRGB - Texture, pattern: "*srgb_texture*", extension: "*"}
  - !<Rule> {name: acescg, colorspace: ACEScg, pattern: "*ACEScg*", extension: "*"}
  - !<Rule> {name: lin_rec709, colorspace: Linear Rec.709 (sRGB), pattern: "*lin_rec709*", extension: "*"}
  - !<Rule> {name: lin_srgb, colorspace: Linear Rec.709 (sRGB), pattern: "*lin_srgb*", extension: "*"}

  # --------------------------------------------------------------------------
  # 02. Houdini / MoonRay .tx rule
  # Keep .tx Raw because utility .tx maps are data, and basecolor .tx should
  # already be converted to ACEScg by maketx/oiiotool before rendering.
  # This avoids OCIO applying a second transform to .tx files.
  # --------------------------------------------------------------------------

  - !<Rule> {name: tx, colorspace: Raw, pattern: "*", extension: tx}

  # --------------------------------------------------------------------------
  # 03. PBR / utility maps that are always data
  # Keep these before generic byte-image rules.
  # Color-bearing material maps are handled separately below.
  # --------------------------------------------------------------------------

  - !<Rule> {name: PBR_Data_Maps, colorspace: Raw, regex: ".*(_(Normal|normal|NRM|nrm|Norm|norm|NormalGL|normalGL|NormalDX|normalDX|Roughness|roughness|Rough|rough|Metallic|metallic|Metalness|metalness|Metal|metal|Height|height|Displacement|displacement|Disp|disp|Bump|bump|AmbientOcclusion|ambientOcclusion|Occlusion|occlusion|AO|ao|Glossiness|glossiness|Gloss|gloss|Cavity|cavity|Curvature|curvature|Thickness|thickness|Anisotropy|anisotropy|Aniso|aniso|AnisotropyLevel|anisotropyLevel|Anisotropy_Level|anisotropy_level|AnisoLevel|anisoLevel|Aniso_Level|aniso_level|AnisotropyAngle|anisotropyAngle|Anisotropy_Angle|anisotropy_angle|AnisoAngle|anisoAngle|Aniso_Angle|aniso_angle|Mask|mask|ID|id|MatID|matid|Opacity|opacity|Alpha|alpha|_nm|_nrm|_normal|_rough|_roughness|_rm|_metal|_metallic|_metalness|_mm|_height|_hm|_disp|_dm|_bump|_ao|_occ|_gloss|_gm|_cavity|_cm|_curv|_thick|_aniso|_anisotropy|_anisolevel|_aniso_level|_anisotropy_level|_anisoangle|_aniso_angle|_anisotropy_angle|_mask|_id|_opacity|_alpha|_arm|_orm|_om)).*"}

  - !<Rule> {name: PBR_Mask_Maps, colorspace: Raw, regex: ".*(_(SubsurfaceMask|subsurfaceMask|Subsurface_Mask|subsurface_mask|SSSMask|sssMask|SSS_Mask|sss_mask|TransmissionMask|transmissionMask|Transmission_Mask|transmission_mask|TranslucencyMask|translucencyMask|Translucency_Mask|translucency_mask|SpecularLevel|specularLevel|Specular_Level|specular_level|SpecularAmount|specularAmount|Specular_Amount|specular_amount|CoatMask|coatMask|Coat_Mask|coat_mask|SheenMask|sheenMask|Sheen_Mask|sheen_mask)).*"}

  # --------------------------------------------------------------------------
  # 04. Color-bearing texture maps
  # Byte-image basecolor/albedo/diffuse/color maps are sRGB.
  # Ambiguous SSS/transmission/specular maps are treated as color only when
  # their names explicitly say color/colour.
  # --------------------------------------------------------------------------

  - !<Rule> {name: BaseColor_Byte_Images, colorspace: sRGB - Texture, regex: ".*(_(BaseColor|baseColor|basecolor|Base_Color|base_color|Albedo|albedo|Diffuse|diffuse|Diff|diff|Color|color|Colour|colour|Col|col|Base|base)).*\\.(png|jpg|jpeg|tga|tif|tiff|bmp|webp)$"}

  - !<Rule> {name: Material_Color_Byte_Images, colorspace: sRGB - Texture, regex: ".*(_(SubsurfaceColor|subsurfaceColor|Subsurface_Color|subsurface_color|SSSColor|sssColor|SSS_Color|sss_color|TransmissionColor|transmissionColor|Transmission_Color|transmission_color|TranslucencyColor|translucencyColor|Translucency_Color|translucency_color|SpecularColor|specularColor|Specular_Color|specular_color|CoatColor|coatColor|Coat_Color|coat_color|SheenColor|sheenColor|Sheen_Color|sheen_color)).*\\.(png|jpg|jpeg|tga|tif|tiff|bmp|webp)$"}

  # --------------------------------------------------------------------------
  # 05. USDZ embedded texture rules
  # Kept from the current ACEScg config, with tga added for parity.
  # --------------------------------------------------------------------------

  - !<Rule> {name: __usdz_jpg, colorspace: sRGB - Texture, regex: ".[uu][ss][dd][zz]\\[.*[jj][pp][gg]\\]"}
  - !<Rule> {name: __usdz_jpeg, colorspace: sRGB - Texture, regex: ".[uu][ss][dd][zz]\\[.*[jj][pp][ee][gg]\\]"}
  - !<Rule> {name: __usdz_tga, colorspace: sRGB - Texture, regex: ".[uu][ss][dd][zz]\\[.*[tt][gg][aa]\\]"}
  - !<Rule> {name: __usdz_png, colorspace: sRGB - Texture, regex: ".[uu][ss][dd][zz]\\[.*[pp][nn][gg]\\]"}
  - !<Rule> {name: __usdz_tif, colorspace: sRGB - Texture, regex: ".[uu][ss][dd][zz]\\[.*[tt][ii][ff]\\]"}
  - !<Rule> {name: __usdz_tiff, colorspace: sRGB - Texture, regex: ".[uu][ss][dd][zz]\\[.*[tt][ii][ff][ff]\\]"}
  - !<Rule> {name: __usdz_exr, colorspace: ACEScg, regex: ".[uu][ss][dd][zz]\\[.*[ee][xx][rr]\\]"}

  # --------------------------------------------------------------------------
  # 06. Standard byte image formats
  # Generic fallback. Utility maps should already be caught above.
  # --------------------------------------------------------------------------

  - !<Rule> {name: jpg,  colorspace: sRGB - Texture, pattern: "*", extension: jpg}
  - !<Rule> {name: jpeg, colorspace: sRGB - Texture, pattern: "*", extension: jpeg}
  - !<Rule> {name: tga,  colorspace: sRGB - Texture, pattern: "*", extension: tga}
  - !<Rule> {name: png,  colorspace: sRGB - Texture, pattern: "*", extension: png}
  - !<Rule> {name: tif,  colorspace: sRGB - Texture, pattern: "*", extension: tif}
  - !<Rule> {name: tiff, colorspace: sRGB - Texture, pattern: "*", extension: tiff}
  - !<Rule> {name: bmp,  colorspace: sRGB - Texture, pattern: "*", extension: bmp}
  - !<Rule> {name: webp, colorspace: sRGB - Texture, pattern: "*", extension: webp}

  # --------------------------------------------------------------------------
  # 07. Floating / HDR formats
  # EXR defaults to ACEScg in this personal MoonRay config.
  # HDRIs stay Linear Rec.709 unless intentionally converted.
  # --------------------------------------------------------------------------

  - !<Rule> {name: exr, colorspace: ACEScg, pattern: "*", extension: exr}
  - !<Rule> {name: hdr, colorspace: Linear Rec.709 (sRGB), pattern: "*", extension: hdr}

  # --------------------------------------------------------------------------
  # 08. OCIO color-space-name path search and final fallback
  # --------------------------------------------------------------------------

  - !<Rule> {name: ColorSpaceNamePathSearch}
  - !<Rule> {name: Default, colorspace: ACEScg}
shared_views:
  - !<View> {name: ACES 2.0 - SDR 100 nits (Rec.709), view_transform: ACES 2.0 - SDR 100 nits (Rec.709), display_colorspace: <USE_DISPLAY_NAME>}
  - !<View> {name: ACES 2.0 - SDR 100 nits (P3 D65), view_transform: ACES 2.0 - SDR 100 nits (P3 D65), display_colorspace: <USE_DISPLAY_NAME>}
  - !<View> {name: ACES 2.0 - SDR 100 nits (Rec.709) - Film Dense, view_transform: ACES 2.0 - SDR 100 nits (Rec.709), display_colorspace: <USE_DISPLAY_NAME>, looks: "ACES 1.3 Reference Gamut Compression, Film Dense"}
  - !<View> {name: ACES 2.0 - SDR 100 nits (Rec.709) - Photochemical, view_transform: ACES 2.0 - SDR 100 nits (Rec.709), display_colorspace: <USE_DISPLAY_NAME>, looks: "ACES 1.3 Reference Gamut Compression, Photochemical"}
  - !<View> {name: ACES 2.0 - SDR 100 nits (Rec.709) - Vitrine, view_transform: ACES 2.0 - SDR 100 nits (Rec.709), display_colorspace: <USE_DISPLAY_NAME>, looks: "ACES 1.3 Reference Gamut Compression, Vitrine"}
  - !<View> {name: ACES 2.0 - SDR 100 nits (Rec.709) - Chemical Drift, view_transform: ACES 2.0 - SDR 100 nits (Rec.709), display_colorspace: <USE_DISPLAY_NAME>, looks: "ACES 1.3 Reference Gamut Compression, Chemical Drift"}
  - !<View> {name: ACES 2.0 - SDR 100 nits (Rec.709) - Phoenix Drift, view_transform: ACES 2.0 - SDR 100 nits (Rec.709), display_colorspace: <USE_DISPLAY_NAME>, looks: "ACES 1.3 Reference Gamut Compression, Phoenix Drift"}
  - !<View> {name: ACES 2.0 - SDR 100 nits (Rec.709) - Archival Warm-Gray, view_transform: ACES 2.0 - SDR 100 nits (Rec.709), display_colorspace: <USE_DISPLAY_NAME>, looks: "ACES 1.3 Reference Gamut Compression, Archival Warm-Gray"}
  - !<View> {name: ACES 2.0 - SDR 100 nits (Rec.709) - Carbon Plate, view_transform: ACES 2.0 - SDR 100 nits (Rec.709), display_colorspace: <USE_DISPLAY_NAME>, looks: "ACES 1.3 Reference Gamut Compression, Carbon Plate"}
  - !<View> {name: ACES 2.0 - SDR 100 nits (Rec.709) - Carbon Black, view_transform: ACES 2.0 - SDR 100 nits (Rec.709), display_colorspace: <USE_DISPLAY_NAME>, looks: "ACES 1.3 Reference Gamut Compression, Carbon Black"}
  - !<View> {name: ACES 2.0 - SDR 100 nits (Rec.709) - Cold Steel Neutral, view_transform: ACES 2.0 - SDR 100 nits (Rec.709), display_colorspace: <USE_DISPLAY_NAME>, looks: "ACES 1.3 Reference Gamut Compression, Cold Steel Neutral"}
  - !<View> {name: ACES 2.0 - SDR 100 nits (Rec.709) - Editorial Split, view_transform: ACES 2.0 - SDR 100 nits (Rec.709), display_colorspace: <USE_DISPLAY_NAME>, looks: "ACES 1.3 Reference Gamut Compression, Editorial Split"}
  - !<View> {name: ACES 2.0 - SDR 100 nits (Rec.709) - Graphite Matte, view_transform: ACES 2.0 - SDR 100 nits (Rec.709), display_colorspace: <USE_DISPLAY_NAME>, looks: "ACES 1.3 Reference Gamut Compression, Graphite Matte"}
  - !<View> {name: ACES 2.0 - SDR 100 nits (P3 D65) - Film Dense, view_transform: ACES 2.0 - SDR 100 nits (P3 D65), display_colorspace: <USE_DISPLAY_NAME>, looks: "ACES 1.3 Reference Gamut Compression, Film Dense"}
  - !<View> {name: ACES 2.0 - SDR 100 nits (P3 D65) - Photochemical, view_transform: ACES 2.0 - SDR 100 nits (P3 D65), display_colorspace: <USE_DISPLAY_NAME>, looks: "ACES 1.3 Reference Gamut Compression, Photochemical"}
  - !<View> {name: ACES 2.0 - SDR 100 nits (P3 D65) - Vitrine, view_transform: ACES 2.0 - SDR 100 nits (P3 D65), display_colorspace: <USE_DISPLAY_NAME>, looks: "ACES 1.3 Reference Gamut Compression, Vitrine"}
  - !<View> {name: ACES 2.0 - SDR 100 nits (P3 D65) - Chemical Drift, view_transform: ACES 2.0 - SDR 100 nits (P3 D65), display_colorspace: <USE_DISPLAY_NAME>, looks: "ACES 1.3 Reference Gamut Compression, Chemical Drift"}
  - !<View> {name: ACES 2.0 - SDR 100 nits (P3 D65) - Phoenix Drift, view_transform: ACES 2.0 - SDR 100 nits (P3 D65), display_colorspace: <USE_DISPLAY_NAME>, looks: "ACES 1.3 Reference Gamut Compression, Phoenix Drift"}
  - !<View> {name: ACES 2.0 - SDR 100 nits (P3 D65) - Archival Warm-Gray, view_transform: ACES 2.0 - SDR 100 nits (P3 D65), display_colorspace: <USE_DISPLAY_NAME>, looks: "ACES 1.3 Reference Gamut Compression, Archival Warm-Gray"}
