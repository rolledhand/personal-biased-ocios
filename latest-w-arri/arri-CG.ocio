looks:
  - !<Look>
    name: ACES 1.3 Reference Gamut Compression
    process_space: ACES2065-1
    description: |
      LMT (applied in ACES2065-1) to compress scene-referred values from common cameras into the AP1 gamut

      ACEStransformID: urn:ampas:aces:transformId:v1.5:LMT.Academy.GamutCompress.a1.3.0
    transform: !<BuiltinTransform> {style: ACES-LMT - ACES 1.3 Reference Gamut Compression}

  # ---- ARRI Reveal creative looks, retargeted from config-2020 look recipes into ARRI LogC4 process space ----
  - !<Look>
    name: ARRI Reveal - Editorial Soft
    process_space: ARRI LogC4
    description: |
      Editorial Soft look for ARRI Reveal, slightly reducing contrast and saturation for editorial review.
    transform: !<GroupTransform>
      children:
        - !<CDLTransform> {slope: [1, 1, 1], offset: [0, 0, 0], power: [1, 1, 1], saturation: 0.95}
        - !<MatrixTransform> {matrix: [0.98, 0, 0, 0, 0, 0.98, 0, 0, 0, 0, 0.98, 0, 0, 0, 0, 1]}

  - !<Look>
    name: ARRI Reveal - Editorial Split
    process_space: ARRI LogC4
    description: |
      Editorial Split look for ARRI Reveal, applies a split tone for editorial review.
    transform: !<GroupTransform>
      children:
        - !<CDLTransform> {slope: [1.05, 1, 0.95], offset: [0, 0, 0], power: [1, 1, 1], saturation: 1}

  - !<Look>
    name: ARRI Reveal - Hard Contrast
    process_space: ARRI LogC4
    description: |
      Harder contrast emulation for ARRI Reveal.
    transform: !<CDLTransform> {slope: [1.1, 1.1, 1.1], offset: [0, 0, 0], power: [1, 1, 1.05], saturation: 1.05}

  - !<Look>
    name: ARRI Reveal - Film Dense
    process_space: ARRI LogC4
    description: |
      Denser film look for ARRI Reveal, emulating print density.
    transform: !<CDLTransform> {slope: [0.97, 0.97, 0.97], offset: [0, 0, 0], power: [1.08, 1.08, 1.08], saturation: 1.0}

  - !<Look>
    name: ARRI Reveal - Photochemical
    process_space: ARRI LogC4
    description: |
      Photochemical film emulation for ARRI Reveal.
    transform: !<CDLTransform> {slope: [1.04, 1.01, 0.97], offset: [0, 0, 0], power: [1, 1, 1], saturation: 1.02}

  - !<Look>
    name: ARRI Reveal - Chemical Drift
    process_space: ARRI LogC4
    description: |
      Simulates chemical drift and magenta shift in photochemical prints for ARRI Reveal.
    transform: !<CDLTransform> {slope: [1, 0.98, 1.03], offset: [0, 0, 0], power: [1, 1, 1], saturation: 0.98}

  - !<Look>
    name: ARRI Reveal - Tarnished Print
    process_space: ARRI LogC4
    description: |
      Simulates tarnished film print for ARRI Reveal.
    transform: !<CDLTransform> {slope: [0.95, 0.96, 1.01], offset: [0, 0, 0], power: [1, 1, 1], saturation: 0.96}

  - !<Look>
    name: ARRI Reveal - Negative Dust
    process_space: ARRI LogC4
    description: |
      Simulates negative dust effect for ARRI Reveal.
    transform: !<CDLTransform> {slope: [1, 1, 1], offset: [0.01, 0.01, 0.01], power: [1, 1, 1], saturation: 0.99}

  - !<Look>
    name: ARRI Reveal - Archival Warm-Gray
    process_space: ARRI LogC4
    description: |
      Warm-gray archival print simulation for ARRI Reveal.
    transform: !<CDLTransform> {slope: [1, 0.98, 0.96], offset: [0, 0, 0], power: [1, 1, 1], saturation: 0.98}

  - !<Look>
    name: ARRI Reveal - Archival Extreme Matte
    process_space: ARRI LogC4
    description: |
      Extreme matte archival print simulation for ARRI Reveal.
    transform: !<CDLTransform> {slope: [0.92, 0.92, 0.92], offset: [0, 0, 0], power: [1.1, 1.1, 1.1], saturation: 0.95}

  - !<Look>
    name: ARRI Reveal - Graphite Matte
    process_space: ARRI LogC4
    description: |
      Graphite matte look for ARRI Reveal.
    transform: !<CDLTransform> {slope: [0.99, 0.99, 0.99], offset: [0, 0, 0], power: [1.03, 1.03, 1.03], saturation: 0.97}

  - !<Look>
    name: ARRI Reveal - Soot
    process_space: ARRI LogC4
    description: |
      Sooty, muted look for ARRI Reveal.
    transform: !<CDLTransform> {slope: [0.95, 0.95, 0.95], offset: [0, 0, 0], power: [1, 1, 1], saturation: 0.92}

  - !<Look>
    name: ARRI Reveal - Carbon Plate
    process_space: ARRI LogC4
    description: |
      Carbon plate emulation for ARRI Reveal.
    transform: !<CDLTransform> {slope: [1.02, 1.01, 0.98], offset: [0, 0, 0], power: [1, 1, 1], saturation: 1.01}

  - !<Look>
    name: ARRI Reveal - Carbon Black
    process_space: ARRI LogC4
    description: |
      Deep carbon black simulation for ARRI Reveal.
    transform: !<CDLTransform> {slope: [1.05, 1.05, 1.05], offset: [0, 0, 0], power: [1.05, 1.05, 1.05], saturation: 1.05}

  - !<Look>
    name: ARRI Reveal - Cold Steel Neutral
    process_space: ARRI LogC4
    description: |
      Neutral cold steel look for ARRI Reveal.
    transform: !<CDLTransform> {slope: [0.97, 0.99, 1.03], offset: [0, 0, 0], power: [1, 1, 1], saturation: 0.97}

  - !<Look>
    name: ARRI Reveal - Blue Carbon Print
    process_space: ARRI LogC4
    description: |
      Blue carbon print simulation for ARRI Reveal.
    transform: !<CDLTransform> {slope: [0.98, 1.01, 1.05], offset: [0, 0, 0], power: [1, 1, 1], saturation: 1.03}

  - !<Look>
    name: ARRI Reveal - Funeral Bronze
    process_space: ARRI LogC4
    description: |
      Funeral bronze print simulation for ARRI Reveal.
    transform: !<CDLTransform> {slope: [1.01, 0.98, 0.97], offset: [0, 0, 0], power: [1, 1, 1], saturation: 0.97}

  - !<Look>
    name: ARRI Reveal - Verdigris Shadow
    process_space: ARRI LogC4
    description: |
      Verdigris shadow simulation for ARRI Reveal.
    transform: !<CDLTransform> {slope: [0.96, 1.01, 0.98], offset: [0, 0, 0], power: [1, 1, 1], saturation: 1.01}

  - !<Look>
    name: ARRI Reveal - Phoenix Drift
    process_space: ARRI LogC4
    description: |
      Phoenix drift simulation for ARRI Reveal.
    transform: !<CDLTransform> {slope: [1.03, 1.01, 0.97], offset: [0, 0, 0], power: [1, 1, 1], saturation: 1.02}

  - !<Look>
    name: ARRI Reveal - Power Purity Boost 1
    process_space: ARRI LogC4
    description: |
      Power Purity Boost 1 look for ARRI Reveal.
    transform: !<CDLTransform> {slope: [1.08, 1.08, 1.08], offset: [0, 0, 0], power: [1, 1, 1], saturation: 1.08}

  - !<Look>
    name: ARRI Reveal - Power Purity Boost 2
    process_space: ARRI LogC4
    description: |
