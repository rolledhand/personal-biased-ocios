ocio_profile_version: 2.3

environment:
  {}
search_path:
  - ""
  - luts
strictparsing: true
luma: [0.2126, 0.7152, 0.0722]
name: arri-studio-combined-config-v1.0.0_aces-v1.3_ocio-v2.1
description: |
  ARRI Studio Config - Built on top of the following ACES Config:

  ARRI Studio Config - Built on top of the following ACES Config:

  Academy Color Encoding System - Studio Config [COLORSPACES v1.0.0] [ACES v1.3] [OCIO v2.1]
  ------------------------------------------------------------------------------------------

  This "OpenColorIO" config is geared toward studios requiring a config that includes a wide variety of camera colorspaces, displays and looks.

  Generated with "OpenColorIO-Config-ACES" v1.0.0 on the 2022/10/26 at 05:59.

roles:
  aces_interchange: ACES2065-1
  cie_xyz_d65_interchange: CIE-XYZ-D65

  data: Raw

  # MoonRay / Houdini personal render-space defaults
  default: Linear ARRI Wide Gamut 4
  scene_linear: Linear ARRI Wide Gamut 4
  rendering: Linear ARRI Wide Gamut 4
  reference: Linear ARRI Wide Gamut 4
  default_float: Linear ARRI Wide Gamut 4

  # Byte/UI defaults
  default_byte: Gamma 2.4 Rec.709 - Texture
  default_sequencer: Gamma 2.4 Rec.709 - Texture
  color_picking: Gamma 2.4 Rec.709 - Texture
  texture_paint: Gamma 2.4 Rec.709 - Texture

  # Log / grading defaults
  matte_paint: ARRI LogC4
  color_timing: ARRI LogC4
  compositing_log: ARRI LogC4

  # Useful app aliases
  srgb_linear: Linear Rec.709 (sRGB)

file_rules:
  # --------------------------------------------------------------------------
  # 01. Explicit path/name overrides
  # --------------------------------------------------------------------------

  - !<Rule> {name: explicit_awg4_name, colorspace: Linear ARRI Wide Gamut 4, regex: ".*(Linear ARRI Wide Gamut 4|linear_arri_wide_gamut_4|lin_arri_wide_gamut_4|lin_awg4|AWG4|awg4).*"}
  - !<Rule> {name: explicit_logc4_name, colorspace: ARRI LogC4, regex: ".*(ARRI LogC4|arri_logc4|LogC4|logc4).*"}
  - !<Rule> {name: explicit_acescg_name, colorspace: ACEScg, regex: ".*(ACEScg|acescg|lin_ap1).*"}
  - !<Rule> {name: explicit_aces2065_name, colorspace: ACES2065-1, regex: ".*(ACES2065-1|aces2065|ACES_2065|AP0|ap0).*"}
  - !<Rule> {name: explicit_linear_rec709_name, colorspace: Linear Rec.709 (sRGB), regex: ".*(Linear Rec\\.709|Linear BT\\.709|linear_rec709|lin_rec709|linrec709|linear_bt709|lin_bt709|linear_srgb|lin_srgb).*"}
  - !<Rule> {name: explicit_srgb_texture_name, colorspace: sRGB - Texture, regex: ".*(sRGB - Texture|srgb_texture|srgb_tx|sRGB|srgb).*"}
  - !<Rule> {name: explicit_raw_name, colorspace: Raw, regex: ".*([rR][aA][wW]|data|noncolor|non_color|utility_raw).*"}

  # --------------------------------------------------------------------------
  # 02. Houdini / MoonRay .tx rule
  # Keep .tx Raw because utility .tx maps are data, and basecolor .tx should
  # already be converted to Linear ARRI Wide Gamut 4 by maketx.
  # --------------------------------------------------------------------------

  - !<Rule> {name: tx, colorspace: Raw, pattern: "*", extension: tx}

  # --------------------------------------------------------------------------
  # 03. PBR / utility maps
  # Keep this before generic byte-image rules.
  # --------------------------------------------------------------------------

  - !<Rule> {name: PBRMaps, colorspace: Raw, regex: ".*(_(Normal|normal|NRM|nrm|Norm|norm|NormalGL|normalGL|NormalDX|normalDX|Roughness|roughness|Rough|rough|Metallic|metallic|Metalness|metalness|Metal|metal|Height|height|Displacement|displacement|Disp|disp|Bump|bump|AmbientOcclusion|ambientOcclusion|Occlusion|occlusion|AO|ao|Specular|specular|Spec|spec|Glossiness|glossiness|Gloss|gloss|Cavity|cavity|Curvature|curvature|Thickness|thickness|Subsurface|subsurface|SubsurfaceScattering|subsurfaceScattering|SSS|sss|Transmission|transmission|Translucency|translucency|Alpha|alpha|Opacity|opacity|Mask|mask|ID|id|MatID|matid|_nm|_nrm|_normal|_rough|_roughness|_rm|_metal|_metallic|_metalness|_mm|_height|_hm|_disp|_dm|_bump|_ao|_occ|_spec|_sm|_gloss|_gm|_cavity|_cm|_curv|_thick|_sss|_sssm|_alpha|_opacity|_mask|_id|_arm|_orm|_om)).*"}

  # --------------------------------------------------------------------------
  # 04. Base color / color texture maps
  # Byte image basecolor/albedo/diffuse/color maps default to Gamma 2.4 Rec.709 textures in this ARRI/AWG4 CG pipeline.
  # --------------------------------------------------------------------------

  - !<Rule> {name: BaseColor_Byte_Images, colorspace: Gamma 2.4 Rec.709 - Texture, regex: ".*(_(BaseColor|baseColor|basecolor|Base_Color|base_color|Albedo|albedo|Diffuse|diffuse|Diff|diff|Color|color|Colour|colour|Col|col|Base|base)).*\\.(png|jpg|jpeg|tga|tif|tiff|bmp|webp)$"}

  # --------------------------------------------------------------------------
  # 05. Standard byte image formats
  # Generic fallback. Utility maps should already be caught above. Explicit srgb/sRGB filenames still override to sRGB - Texture.
  # --------------------------------------------------------------------------

  - !<Rule> {name: jpg,  colorspace: Gamma 2.4 Rec.709 - Texture, pattern: "*", extension: jpg}
  - !<Rule> {name: jpeg, colorspace: Gamma 2.4 Rec.709 - Texture, pattern: "*", extension: jpeg}
  - !<Rule> {name: tga,  colorspace: Gamma 2.4 Rec.709 - Texture, pattern: "*", extension: tga}
  - !<Rule> {name: png,  colorspace: Gamma 2.4 Rec.709 - Texture, pattern: "*", extension: png}
  - !<Rule> {name: tif,  colorspace: Gamma 2.4 Rec.709 - Texture, pattern: "*", extension: tif}
  - !<Rule> {name: tiff, colorspace: Gamma 2.4 Rec.709 - Texture, pattern: "*", extension: tiff}
  - !<Rule> {name: bmp,  colorspace: Gamma 2.4 Rec.709 - Texture, pattern: "*", extension: bmp}
  - !<Rule> {name: webp, colorspace: Gamma 2.4 Rec.709 - Texture, pattern: "*", extension: webp}

  # --------------------------------------------------------------------------
  # 06. Floating / HDR formats
  # EXR defaults to Linear ARRI Wide Gamut 4 in this personal MoonRay config.
  # --------------------------------------------------------------------------

  - !<Rule> {name: exr, colorspace: Linear ARRI Wide Gamut 4, pattern: "*", extension: exr}
  - !<Rule> {name: hdr, colorspace: Linear Rec.709 (sRGB), pattern: "*", extension: hdr}

  # --------------------------------------------------------------------------
  # 07. USDZ embedded texture rules
  # --------------------------------------------------------------------------

  - !<Rule> {name: __usdz_jpg, colorspace: Gamma 2.4 Rec.709 - Texture, regex: ".*[uu][ss][dd][zz]\\[.*[jj][pp][gg]\\]"}
  - !<Rule> {name: __usdz_jpeg, colorspace: Gamma 2.4 Rec.709 - Texture, regex: ".*[uu][ss][dd][zz]\\[.*[jj][pp][ee][gg]\\]"}
  - !<Rule> {name: __usdz_tga, colorspace: Gamma 2.4 Rec.709 - Texture, regex: ".*[uu][ss][dd][zz]\\[.*[tt][gg][aa]\\]"}
  - !<Rule> {name: __usdz_png, colorspace: Gamma 2.4 Rec.709 - Texture, regex: ".*[uu][ss][dd][zz]\\[.*[pp][nn][gg]\\]"}
  - !<Rule> {name: __usdz_tif, colorspace: Gamma 2.4 Rec.709 - Texture, regex: ".*[uu][ss][dd][zz]\\[.*[tt][ii][ff]\\]"}
  - !<Rule> {name: __usdz_tiff, colorspace: Gamma 2.4 Rec.709 - Texture, regex: ".*[uu][ss][dd][zz]\\[.*[tt][ii][ff][ff]\\]"}
  - !<Rule> {name: __usdz_exr, colorspace: Linear ARRI Wide Gamut 4, regex: ".*[uu][ss][dd][zz]\\[.*[ee][xx][rr]\\]"}

  # --------------------------------------------------------------------------
  # 08. OCIO color-space-name path search and final fallback
  # --------------------------------------------------------------------------

  - !<Rule> {name: ColorSpaceNamePathSearch}
  - !<Rule> {name: Default, colorspace: Linear ARRI Wide Gamut 4}

shared_views:
  - !<View> {name: ACES 1.0 - SDR Video, view_transform: ACES 1.0 - SDR Video, display_colorspace: <USE_DISPLAY_NAME>}
  - !<View> {name: ACES 1.0 - SDR Video (D60 sim on D65), view_transform: ACES 1.0 - SDR Video (D60 sim on D65), display_colorspace: <USE_DISPLAY_NAME>}
  - !<View> {name: ACES 1.1 - SDR Video (P3 lim), view_transform: ACES 1.1 - SDR Video (P3 lim), display_colorspace: <USE_DISPLAY_NAME>}
  - !<View> {name: ACES 1.1 - SDR Video (Rec.709 lim), view_transform: ACES 1.1 - SDR Video (Rec.709 lim), display_colorspace: <USE_DISPLAY_NAME>}
  - !<View> {name: ACES 1.1 - HDR Video (1000 nits & Rec.2020 lim), view_transform: ACES 1.1 - HDR Video (1000 nits & Rec.2020 lim), display_colorspace: <USE_DISPLAY_NAME>}
  - !<View> {name: ACES 1.1 - HDR Video (2000 nits & Rec.2020 lim), view_transform: ACES 1.1 - HDR Video (2000 nits & Rec.2020 lim), display_colorspace: <USE_DISPLAY_NAME>}
  - !<View> {name: ACES 1.1 - HDR Video (4000 nits & Rec.2020 lim), view_transform: ACES 1.1 - HDR Video (4000 nits & Rec.2020 lim), display_colorspace: <USE_DISPLAY_NAME>}
  - !<View> {name: ACES 1.1 - HDR Video (1000 nits & P3 lim), view_transform: ACES 1.1 - HDR Video (1000 nits & P3 lim), display_colorspace: <USE_DISPLAY_NAME>}
  - !<View> {name: ACES 1.1 - HDR Video (2000 nits & P3 lim), view_transform: ACES 1.1 - HDR Video (2000 nits & P3 lim), display_colorspace: <USE_DISPLAY_NAME>}
  - !<View> {name: ACES 1.1 - HDR Video (4000 nits & P3 lim), view_transform: ACES 1.1 - HDR Video (4000 nits & P3 lim), display_colorspace: <USE_DISPLAY_NAME>}
  - !<View> {name: ACES 1.0 - SDR Cinema, view_transform: ACES 1.0 - SDR Cinema, display_colorspace: <USE_DISPLAY_NAME>}
  - !<View> {name: ACES 1.1 - SDR Cinema (D60 sim on D65), view_transform: ACES 1.1 - SDR Cinema (D60 sim on D65), display_colorspace: <USE_DISPLAY_NAME>}
  - !<View> {name: ACES 1.1 - SDR Cinema (Rec.709 lim), view_transform: ACES 1.1 - SDR Cinema (Rec.709 lim), display_colorspace: <USE_DISPLAY_NAME>}
  - !<View> {name: ACES 1.0 - SDR Cinema (D60 sim on DCI), view_transform: ACES 1.0 - SDR Cinema (D60 sim on DCI), display_colorspace: <USE_DISPLAY_NAME>}
  - !<View> {name: ACES 1.1 - SDR Cinema (D65 sim on DCI), view_transform: ACES 1.1 - SDR Cinema (D65 sim on DCI), display_colorspace: <USE_DISPLAY_NAME>}
  - !<View> {name: ACES 1.1 - HDR Cinema (108 nits & P3 lim), view_transform: ACES 1.1 - HDR Cinema (108 nits & P3 lim), display_colorspace: <USE_DISPLAY_NAME>}
  - !<View> {name: Un-tone-mapped, view_transform: Un-tone-mapped, display_colorspace: <USE_DISPLAY_NAME>}

displays:
  sRGB - Display:
    - !<View> {name: Raw, colorspace: Raw}
    - !<Views> [ACES 1.0 - SDR Video, ACES 1.0 - SDR Video (D60 sim on D65), Un-tone-mapped]
