displays:
  sRGB - Display:
    - !<View> {name: Raw, colorspace: Raw}
    - !<Views> [ACES 2.0 - SDR 100 nits (Rec.709), ACES 2.0 - SDR 100 nits (Rec.709) - Editorial Split, ACES 2.0 - SDR 100 nits (Rec.709) - Editorial Split (CDL Stack), ACES 2.0 - SDR 100 nits (Rec.709) - Graphite Matte, ACES 2.0 - SDR 100 nits (Rec.709) - Graphite Matte (CDL Shift), ACES 2.0 - SDR 100 nits (Rec.709) - Graphite Matte (CDL Shift 2), ACES 2.0 - SDR 100 nits (Rec.709) - Cold Steel Neutral, ACES 2.0 - SDR 100 nits (Rec.709) - Carbon Black, ACES 2.0 - SDR 100 nits (Rec.709) - Carbon Black (CDL Shift 2), ACES 2.0 - SDR 100 nits (Rec.709) - Carbon Plate, ACES 2.0 - SDR 100 nits (Rec.709) - Carbon Plate (CDL Shift), ACES 2.0 - SDR 100 nits (Rec.709) - Archival Warm-Gray, ACES 2.0 - SDR 100 nits (Rec.709) - Archival Warm-Gray (CDL Shift), ACES 2.0 - SDR 100 nits (Rec.709) - Archival Warm-Gray (CDL Shift 2), ACES 2.0 - SDR 100 nits (Rec.709) - Archival Warm-Gray (CDL Stack), ACES 2.0 - SDR 100 nits (Rec.709) - Archival Extreme Matte (CDL Matte Fade), ACES 2.0 - SDR 100 nits (Rec.709) - Film Dense, ACES 2.0 - SDR 100 nits (Rec.709) - Film Dense (CDL Shift), ACES 2.0 - SDR 100 nits (Rec.709) - Film Dense (CDL Stack), ACES 2.0 - SDR 100 nits (Rec.709) - Photochemical, ACES 2.0 - SDR 100 nits (Rec.709) - Photochemical (CDL Shift), ACES 2.0 - SDR 100 nits (Rec.709) - Photochemical (CDL Shift 2), ACES 2.0 - SDR 100 nits (Rec.709) - Photochemical (CDL Stack), ACES 2.0 - SDR 100 nits (Rec.709) - Vitrine, ACES 2.0 - SDR 100 nits (Rec.709) - Vitrine (CDL Shift 2), ACES 2.0 - SDR 100 nits (Rec.709) - Chemical Drift, ACES 2.0 - SDR 100 nits (Rec.709) - Chemical Drift (CDL Shift 2), ACES 2.0 - SDR 100 nits (Rec.709) - Chemical Drift (CDL Stack), ACES 2.0 - SDR 100 nits (Rec.709) - Phoenix Drift, ACES 2.0 - SDR 100 nits (Rec.709) - Phoenix Drift (CDL Shift), ACES 2.0 - SDR 100 nits (Rec.709) - Phoenix Drift (CDL Shift 2), ACES 2.0 - SDR 100 nits (Rec.709) - Phoenix Drift (CDL Stack)]
