ocio_profile_version: 2.4
environment:
  {}
search_path: ""
strictparsing: true
luma: [0.2126, 0.7152, 0.0722]
name: cg-config-v3.0.0_aces-v2.0_ocio-v2.4
description: |
  Academy Color Encoding System - CG Config [COLORSPACES v3.0.0] [ACES v2.0] [OCIO v2.4]
  --------------------------------------------------------------------------------------
  This minimalistic "OpenColorIO" config is geared toward computer graphics artists requiring a lean config that does not include camera colorspaces and the less common displays and looks.
roles:
  aces_interchange: ACES2065-1
  cie_xyz_d65_interchange: CIE XYZ-D65 - Display-referred
  color_picking: sRGB - Texture
  color_timing: ACEScct
  compositing_log: ACEScct
  data: Raw
  default: ACEScg
  matte_paint: ACEScct
  reference: ACEScg
  scene_linear: ACEScg
  texture_paint: sRGB - Texture
file_rules:
  - !<Rule> {name: srgb_tx, colorspace: sRGB - Texture, pattern: "*srgb_tx*", extension: "*"}
  - !<Rule> {name: srgb_texture, colorspace: sRGB - Texture, pattern: "*srgb_texture*", extension: "*"}
  - !<Rule> {name: acescg, colorspace: ACEScg, pattern: "*ACEScg*", extension: "*"}
  - !<Rule> {name: lin_rec709, colorspace: Linear Rec.709 (sRGB), pattern: "*lin_rec709*", extension: "*"}
  - !<Rule> {name: lin_srgb, colorspace: Linear Rec.709 (sRGB), pattern: "*lin_srgb*", extension: "*"}
  - !<Rule> {name: __usdz_jpg, colorspace: sRGB - Texture, regex: ".[uu][ss][dd][zz]\\[.*[jj][pp][gg]\\]"}
  - !<Rule> {name: __usdz_jpeg, colorspace: sRGB - Texture, regex: ".[uu][ss][dd][zz]\\[.*[jj][pp][ee][gg]\\]"}
  - !<Rule> {name: __usdz_png, colorspace: sRGB - Texture, regex: ".[uu][ss][dd][zz]\\[.*[pp][nn][gg]\\]"}
  - !<Rule> {name: __usdz_tif, colorspace: sRGB - Texture, regex: ".[uu][ss][dd][zz]\\[.*[tt][ii][ff]\\]"}
  - !<Rule> {name: __usdz_tiff, colorspace: sRGB - Texture, regex: ".[uu][ss][dd][zz]\\[.*[tt][ii][ff][ff]\\]"}
  - !<Rule> {name: __usdz_exr, colorspace: ACEScg, regex: ".[uu][ss][dd][zz]\\[.*[ee][xx][rr]\\]"}
  - !<Rule> {name: jpg,  colorspace: sRGB - Texture, pattern: "*", extension: jpg}
  - !<Rule> {name: jpeg, colorspace: sRGB - Texture, pattern: "*", extension: jpeg}
  - !<Rule> {name: png,  colorspace: sRGB - Texture, pattern: "*", extension: png}
  - !<Rule> {name: tif,  colorspace: sRGB - Texture, pattern: "*", extension: tif}
  - !<Rule> {name: tiff, colorspace: sRGB - Texture, pattern: "*", extension: tiff}
  - !<Rule> {name: exr,  colorspace: ACEScg, pattern: "*", extension: exr}
  - !<Rule> {name: Default, colorspace: ACEScg}
shared_views:
  - !<View> {name: ACES 2.0 - SDR 100 nits (Rec.709), view_transform: ACES 2.0 - SDR 100 nits (Rec.709), display_colorspace: <USE_DISPLAY_NAME>}
  - !<View> {name: ACES 2.0 - SDR 100 nits (P3 D65), view_transform: ACES 2.0 - SDR 100 nits (P3 D65), display_colorspace: <USE_DISPLAY_NAME>}
  - !<View> {name: ACES 2.0 - SDR 100 nits (Rec.709) - Film Dense, view_transform: ACES 2.0 - SDR 100 nits (Rec.709), display_colorspace: <USE_DISPLAY_NAME>, looks: "ACES 1.3 Reference Gamut Compression, Film Dense"}
  - !<View> {name: ACES 2.0 - SDR 100 nits (Rec.709) - Film Dense (CDL Stack), view_transform: ACES 2.0 - SDR 100 nits (Rec.709), display_colorspace: <USE_DISPLAY_NAME>, looks: "ACES 1.3 Reference Gamut Compression, Film Dense (CDL Stack)"}
  - !<View> {name: ACES 2.0 - SDR 100 nits (Rec.709) - Film Dense (CDL Shift), view_transform: ACES 2.0 - SDR 100 nits (Rec.709), display_colorspace: <USE_DISPLAY_NAME>, looks: "ACES 1.3 Reference Gamut Compression, Film Dense (CDL Shift)"}
  - !<View> {name: ACES 2.0 - SDR 100 nits (Rec.709) - Photochemical, view_transform: ACES 2.0 - SDR 100 nits (Rec.709), display_colorspace: <USE_DISPLAY_NAME>, looks: "ACES 1.3 Reference Gamut Compression, Photochemical"}
  - !<View> {name: ACES 2.0 - SDR 100 nits (Rec.709) - Photochemical (CDL Stack), view_transform: ACES 2.0 - SDR 100 nits (Rec.709), display_colorspace: <USE_DISPLAY_NAME>, looks: "ACES 1.3 Reference Gamut Compression, Photochemical (CDL Stack)"}
  - !<View> {name: ACES 2.0 - SDR 100 nits (Rec.709) - Photochemical (CDL Shift), view_transform: ACES 2.0 - SDR 100 nits (Rec.709), display_colorspace: <USE_DISPLAY_NAME>, looks: "ACES 1.3 Reference Gamut Compression, Photochemical (CDL Shift)"}
  - !<View> {name: ACES 2.0 - SDR 100 nits (Rec.709) - Photochemical (CDL Shift 2), view_transform: ACES 2.0 - SDR 100 nits (Rec.709), display_colorspace: <USE_DISPLAY_NAME>, looks: "ACES 1.3 Reference Gamut Compression, Photochemical (CDL Shift 2)"}
  - !<View> {name: ACES 2.0 - SDR 100 nits (Rec.709) - Vitrine, view_transform: ACES 2.0 - SDR 100 nits (Rec.709), display_colorspace: <USE_DISPLAY_NAME>, looks: "ACES 1.3 Reference Gamut Compression, Vitrine"}
  - !<View> {name: ACES 2.0 - SDR 100 nits (Rec.709) - Vitrine (CDL Shift 2), view_transform: ACES 2.0 - SDR 100 nits (Rec.709), display_colorspace: <USE_DISPLAY_NAME>, looks: "ACES 1.3 Reference Gamut Compression, Vitrine (CDL Shift 2)"}
  - !<View> {name: ACES 2.0 - SDR 100 nits (Rec.709) - Chemical Drift, view_transform: ACES 2.0 - SDR 100 nits (Rec.709), display_colorspace: <USE_DISPLAY_NAME>, looks: "ACES 1.3 Reference Gamut Compression, Chemical Drift"}
  - !<View> {name: ACES 2.0 - SDR 100 nits (Rec.709) - Chemical Drift (CDL Shift 2), view_transform: ACES 2.0 - SDR 100 nits (Rec.709), display_colorspace: <USE_DISPLAY_NAME>, looks: "ACES 1.3 Reference Gamut Compression, Chemical Drift (CDL Shift 2)"}
  - !<View> {name: ACES 2.0 - SDR 100 nits (Rec.709) - Chemical Drift (CDL Stack), view_transform: ACES 2.0 - SDR 100 nits (Rec.709), display_colorspace: <USE_DISPLAY_NAME>, looks: "ACES 1.3 Reference Gamut Compression, Chemical Drift (CDL Stack)"}
  - !<View> {name: ACES 2.0 - SDR 100 nits (Rec.709) - Phoenix Drift, view_transform: ACES 2.0 - SDR 100 nits (Rec.709), display_colorspace: <USE_DISPLAY_NAME>, looks: "ACES 1.3 Reference Gamut Compression, Phoenix Drift"}
  - !<View> {name: ACES 2.0 - SDR 100 nits (Rec.709) - Phoenix Drift (CDL Stack), view_transform: ACES 2.0 - SDR 100 nits (Rec.709), display_colorspace: <USE_DISPLAY_NAME>, looks: "ACES 1.3 Reference Gamut Compression, Phoenix Drift (CDL Stack)"}
  - !<View> {name: ACES 2.0 - SDR 100 nits (Rec.709) - Phoenix Drift (CDL Shift), view_transform: ACES 2.0 - SDR 100 nits (Rec.709), display_colorspace: <USE_DISPLAY_NAME>, looks: "ACES 1.3 Reference Gamut Compression, Phoenix Drift (CDL Shift)"}
  - !<View> {name: ACES 2.0 - SDR 100 nits (Rec.709) - Phoenix Drift (CDL Shift 2), view_transform: ACES 2.0 - SDR 100 nits (Rec.709), display_colorspace: <USE_DISPLAY_NAME>, looks: "ACES 1.3 Reference Gamut Compression, Phoenix Drift (CDL Shift 2)"}
  - !<View> {name: ACES 2.0 - SDR 100 nits (Rec.709) - Archival Warm-Gray, view_transform: ACES 2.0 - SDR 100 nits (Rec.709), display_colorspace: <USE_DISPLAY_NAME>, looks: "ACES 1.3 Reference Gamut Compression, Archival Warm-Gray"}
  - !<View> {name: ACES 2.0 - SDR 100 nits (Rec.709) - Archival Warm-Gray (CDL Stack), view_transform: ACES 2.0 - SDR 100 nits (Rec.709), display_colorspace: <USE_DISPLAY_NAME>, looks: "ACES 1.3 Reference Gamut Compression, Archival Warm-Gray (CDL Stack)"}
