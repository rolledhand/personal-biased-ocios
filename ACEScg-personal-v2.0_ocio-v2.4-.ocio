inactive_colorspaces: [CIE XYZ-D65 - Display-referred, CIE XYZ-D65 - Scene-referred]
looks:
  - !<Look>
    name: ACES 1.3 Reference Gamut Compression
    process_space: ACES2065-1
    description: |
      LMT (applied in ACES2065-1) to compress scene-referred values from common cameras into the AP1 gamut
      ACEStransformID: urn:ampas:aces:transformId:v2.0:Look.Academy.ReferenceGamutCompress.a2.v1
      AMF Components
      --------------
      ACEStransformID: urn:ampas:aces:transformId:v2.0:InvLook.Academy.ReferenceGamutCompress.a2.v1
    transform: !<BuiltinTransform> {style: ACES-LMT - ACES 1.3 Reference Gamut Compression}
  # Film Soft — printy, gentle, visibly different from Editorial Neutral.
  - !<Look>
    name: Film Soft
    process_space: ACEScct
    description: |
      Gentle print-like base: lifted shadows, very soft shoulder, restrained chroma.
    transform: !<GroupTransform>
      children:
        - !<GradingPrimaryTransform>
          style: log
          contrast: {rgb: [1, 1, 1], master: 1.02}
          saturation: 0.93
        - !<GradingToneTransform>
          style: log
          blacks: {rgb: [1, 1, 1], master: 0.965, start: 0.36, width: 0.48}
          highlights: {rgb: [1, 1, 1], master: 0.972, start: 0.30, pivot: 0.90}
          whites: {rgb: [1, 1, 1], master: 0.995, start: 0.36, width: 0.48}
          s_contrast: 1.00
  # Film Neutral — your everyday film baseline, not too “matte”.
  - !<Look>
    name: Film Neutral
    process_space: ACEScct
    description: |
      Film baseline: clean mids, gentle shoulder, mild sat restraint.
    transform: !<GroupTransform>
      children:
        - !<GradingPrimaryTransform>
          style: log
          contrast: {rgb: [1, 1, 1], master: 1.05}
          saturation: 0.95
        - !<GradingToneTransform>
          style: log
          blacks: {rgb: [1, 1, 1], master: 0.995, start: 0.36, width: 0.48}
          highlights: {rgb: [1, 1, 1], master: 0.980, start: 0.30, pivot: 0.90}
          whites: {rgb: [1, 1, 1], master: 0.992, start: 0.36, width: 0.48}
          s_contrast: 1.01
  # Film Dense — less “contrast crank”, more body via tone + subtle curve.
  - !<Look>
    name: Film Dense
    process_space: ACEScct
    description: |
      Denser film body: thicker low-mids, deep-but-soft blacks, smooth shoulder, lower chroma.
    transform: !<GroupTransform>
      children:
        - !<GradingPrimaryTransform>
          style: log
          contrast: {rgb: [1, 1, 1], master: 1.07}
          saturation: 0.90
        - !<GradingToneTransform>
          style: log
          blacks: {rgb: [1, 1, 1], master: 1.010, start: 0.36, width: 0.48}
          highlights: {rgb: [1, 1, 1], master: 0.972, start: 0.30, pivot: 0.90}
          whites: {rgb: [1, 1, 1], master: 0.988, start: 0.36, width: 0.48}
          s_contrast: 1.02
        - !<GradingRGBCurveTransform>
          style: log
          master: {control_points: [0, 0, 0.40, 0.360, 1, 1]}
  - !<Look>
    name: Photochemical
    process_space: ACEScct
    description: |
      Film-medium shaping with obvious channel crossover, softer shoulder,
      mild print-floor contamination, and non-neutral density.
    transform: !<GroupTransform>
      children:
        - !<GradingPrimaryTransform>
          style: log
          contrast: {rgb: [1, 1, 1], master: 1.08}
          saturation: 0.86
        - !<GradingToneTransform>
          style: log
          blacks:     {rgb: [1, 1, 1], master: 0.972, start: 0.34, width: 0.52}
          highlights: {rgb: [1, 1, 1], master: 0.962, start: 0.27, pivot: 0.87}
          whites:     {rgb: [1, 1, 1], master: 0.982, start: 0.34, width: 0.52}
          s_contrast: 1.00
        - !<GradingRGBCurveTransform>
          style: log
          red:   {control_points: [0, 0, 0.20, 0.193, 0.72, 0.748, 1, 0.995]}
          green: {control_points: [0, 0, 0.20, 0.202, 0.72, 0.718, 1, 0.997]}
          blue:  {control_points: [0, 0, 0.20, 0.212, 0.72, 0.688, 1, 1]}
        - !<CDLTransform>
          {slope: [1.010, 1.000, 0.988], offset: [0.0015, 0.0005, 0.0025], power: [0.986, 1.000, 1.020], sat: 0.94}
  - !<Look>
    name: Photochemical (CDL Reactivated)
    process_space: ACEScct
    description: |
      Photochemical with an ACEScg-linear CDL pre-pass before the ACEScct shaping stack.
      Preserves medium crossover while matching your node-order behavior.
    transform: !<GroupTransform>
      children:
        - !<ColorSpaceTransform> {src: ACEScct, dst: ACEScg}
        - !<CDLTransform>
          {slope: [0.62, 0.62, 0.62], offset: [0.0, 0.0, 0.0], power: [1.24, 1.24, 1.24], sat: 1}
        - !<CDLTransform>
          {slope: [0.86, 0.92, 0.92], offset: [0.014, -0.0055, 0.008], power: [1.1, 1.0, 1.06], sat: 1.42}
        - !<ColorSpaceTransform> {src: ACEScg, dst: ACEScct}
        - !<GradingPrimaryTransform>
          style: log
          contrast: {rgb: [1, 1, 1], master: 1.08}
          saturation: 0.86
        - !<GradingToneTransform>
          style: log
          blacks:     {rgb: [1, 1, 1], master: 0.972, start: 0.34, width: 0.52}
          highlights: {rgb: [1, 1, 1], master: 0.962, start: 0.27, pivot: 0.87}
          whites:     {rgb: [1, 1, 1], master: 0.982, start: 0.34, width: 0.52}
          s_contrast: 1.00
        - !<GradingRGBCurveTransform>
          style: log
          red:   {control_points: [0, 0, 0.20, 0.193, 0.72, 0.748, 1, 0.995]}
          green: {control_points: [0, 0, 0.20, 0.202, 0.72, 0.718, 1, 0.997]}
          blue:  {control_points: [0, 0, 0.20, 0.212, 0.72, 0.688, 1, 1]}
        - !<CDLTransform>
          {slope: [1.010, 1.000, 0.988], offset: [0.0015, 0.0005, 0.0025], power: [0.986, 1.000, 1.020], sat: 0.94}
  # Film Cool — reduce channel curve delta; bias lives lower only.
  - !<Look>
    name: Film Cool
    process_space: ACEScct
    description: |
      Film baseline with subtle cool bias concentrated in shadows/lower-mids (no teal/orange).
    transform: !<GroupTransform>
      children:
        - !<GradingPrimaryTransform>
          style: log
          contrast: {rgb: [1, 1, 1], master: 1.06}
          saturation: 0.93
        - !<GradingToneTransform>
          style: log
          blacks: {rgb: [1, 1, 1], master: 0.995, start: 0.36, width: 0.48}
          highlights: {rgb: [1, 1, 1], master: 0.980, start: 0.30, pivot: 0.90}
          whites: {rgb: [1, 1, 1], master: 0.992, start: 0.36, width: 0.48}
          s_contrast: 1.01
        - !<GradingRGBCurveTransform>
          style: log
          red: {control_points: [0, 0, 0.32, 0.318, 1, 1]}
          blue: {control_points: [0, 0, 0.32, 0.326, 1, 1]}
  # NEW: Film Flat Base — “do nothing but safe shaping” for grading later.
  - !<Look>
    name: Film Flat Base
    process_space: ACEScct
    description: |
      Flat, grade-friendly base: minimal contrast, very gentle shoulder, mild sat restraint.
    transform: !<GroupTransform>
      children:
        - !<GradingPrimaryTransform>
          style: log
          contrast: {rgb: [1, 1, 1], master: 1.00}
          saturation: 0.96
        - !<GradingToneTransform>
          style: log
          blacks: {rgb: [1, 1, 1], master: 0.995, start: 0.36, width: 0.48}
          highlights: {rgb: [1, 1, 1], master: 0.985, start: 0.30, pivot: 0.90}
          whites: {rgb: [1, 1, 1], master: 0.997, start: 0.36, width: 0.48}
          s_contrast: 1.00
  # Editorial Clean — keep premium; avoid “HDR snap”.
  - !<Look>
    name: Editorial Clean
    process_space: ACEScct
    description: |
      Premium editorial: crisp but not crunchy, neutral whites, restrained chroma.
    transform: !<GroupTransform>
      children:
        - !<GradingPrimaryTransform>
          style: log
          contrast: {rgb: [1, 1, 1], master: 1.08}
          saturation: 0.95
        - !<GradingToneTransform>
          style: log
          blacks: {rgb: [1, 1, 1], master: 1.005, start: 0.33, width: 0.42}
          highlights: {rgb: [1, 1, 1], master: 0.992, start: 0.26, pivot: 0.92}
          whites: {rgb: [1, 1, 1], master: 1.000, start: 0.33, width: 0.42}
          s_contrast: 1.02
  # Editorial Neutral — separate from Film Soft: cleaner toe, firmer blacks, less “print lift”.
  - !<Look>
    name: Editorial Neutral
    process_space: ACEScct
    description: |
      Clean-neutral editorial base: firmer blacks than film, flatter than Clean, grade-friendly.
    transform: !<GroupTransform>
      children:
        - !<GradingPrimaryTransform>
          style: log
          contrast: {rgb: [1, 1, 1], master: 1.03}
          saturation: 0.95
        - !<GradingToneTransform>
          style: log
          blacks: {rgb: [1, 1, 1], master: 1.004, start: 0.33, width: 0.42}
          highlights: {rgb: [1, 1, 1], master: 0.995, start: 0.26, pivot: 0.92}
          whites: {rgb: [1, 1, 1], master: 1.000, start: 0.33, width: 0.42}
          s_contrast: 1.00
  # Editorial Punch — stop relying on huge contrast; add body curve instead.
  - !<Look>
    name: Editorial Punch
    process_space: ACEScct
    description: |
      Strongest editorial density: clean, readable, no crunchy blacks; body comes from tone + curve.
    transform: !<GroupTransform>
      children:
        - !<GradingPrimaryTransform>
          style: log
          contrast: {rgb: [1, 1, 1], master: 1.09}
          saturation: 0.95
        - !<GradingToneTransform>
          style: log
          blacks: {rgb: [1, 1, 1], master: 1.012, start: 0.33, width: 0.42}
          highlights: {rgb: [1, 1, 1], master: 0.995, start: 0.26, pivot: 0.92}
          whites: {rgb: [1, 1, 1], master: 1.002, start: 0.33, width: 0.42}
          s_contrast: 1.03
        - !<GradingRGBCurveTransform>
          style: log
          master: {control_points: [0, 0, 0.42, 0.378, 1, 1]}
  # Editorial Matte — reduce excessive lift; keep it premium.
  - !<Look>
    name: Editorial Matte
    process_space: ACEScct
    description: |
      Matte editorial: lifted toe, restrained chroma, still premium (not washed).
    transform: !<GroupTransform>
      children:
        - !<GradingPrimaryTransform>
          style: log
          contrast: {rgb: [1, 1, 1], master: 1.05}
          saturation: 0.92
        - !<GradingToneTransform>
          style: log
          blacks: {rgb: [1, 1, 1], master: 0.970, start: 0.33, width: 0.42}
          highlights: {rgb: [1, 1, 1], master: 0.990, start: 0.26, pivot: 0.90}
          whites: {rgb: [1, 1, 1], master: 0.998, start: 0.33, width: 0.42}
          s_contrast: 1.01
  # NEW: Editorial HiKey — for the white/clean fashion refs, but still restrained.
  - !<Look>
    name: Editorial HiKey
    process_space: ACEScct
    description: |
      Hi-key editorial: brighter mids/whites, clean rolloff, restrained chroma, no harsh snap.
    transform: !<GroupTransform>
      children:
        - !<GradingPrimaryTransform>
          style: log
          brightness: {rgb: [0, 0, 0], master: 0.03}
          contrast: {rgb: [1, 1, 1], master: 1.03}
          saturation: 0.94
        - !<GradingToneTransform>
          style: log
          blacks: {rgb: [1, 1, 1], master: 0.995, start: 0.33, width: 0.42}
          highlights: {rgb: [1, 1, 1], master: 0.990, start: 0.26, pivot: 0.92}
          whites: {rgb: [1, 1, 1], master: 1.010, start: 0.33, width: 0.42}
          s_contrast: 1.00
  # Archival Soft — airy, muted, scanned.
  - !<Look>
    name: Archival Soft
    process_space: ACEScct
    description: |
      Airy archival base: lifted blacks, soft contrast, muted saturation, scan-like.
    transform: !<GroupTransform>
      children:
        - !<GradingPrimaryTransform>
          style: log
          contrast: {rgb: [1, 1, 1], master: 0.99}
          saturation: 0.88
        - !<GradingToneTransform>
          style: log
          blacks: {rgb: [1, 1, 1], master: 0.925, start: 0.32, width: 0.50}
          highlights: {rgb: [1, 1, 1], master: 0.965, start: 0.27, pivot: 0.88}
          whites: {rgb: [1, 1, 1], master: 0.988, start: 0.34, width: 0.50}
          s_contrast: 0.99
  # Archival Warm-Gray — avoid sepia: keep bias subtle, let desat do the work.
  - !<Look>
    name: Archival Warm-Gray
    process_space: ACEScct
    description: |
      Warm-gray archival: lowest chroma, airy floor, paper/scan feel without sepia.
    transform: !<GroupTransform>
      children:
        - !<GradingPrimaryTransform>
          style: log
          contrast: {rgb: [1, 1, 1], master: 0.98}
          saturation: 0.84
        - !<GradingToneTransform>
          style: log
          blacks: {rgb: [1, 1, 1], master: 0.920, start: 0.32, width: 0.50}
          highlights: {rgb: [1, 1, 1], master: 0.968, start: 0.27, pivot: 0.88}
          whites: {rgb: [1, 1, 1], master: 0.984, start: 0.34, width: 0.50}
          s_contrast: 0.98
        - !<GradingRGBCurveTransform>
          style: log
          red: {control_points: [0, 0, 0.30, 0.302, 1, 1]}
          blue: {control_points: [0, 0, 0.30, 0.298, 1, 1]}
  # Archival Dense — more body but still lifted + muted.
  - !<Look>
    name: Archival Dense
    process_space: ACEScct
    description: |
      Denser archival: more body than Soft, still lifted blacks and muted color.
    transform: !<GroupTransform>
      children:
        - !<GradingPrimaryTransform>
          style: log
          contrast: {rgb: [1, 1, 1], master: 1.02}
          saturation: 0.86
        - !<GradingToneTransform>
          style: log
          blacks: {rgb: [1, 1, 1], master: 0.950, start: 0.32, width: 0.50}
          highlights: {rgb: [1, 1, 1], master: 0.972, start: 0.27, pivot: 0.88}
          whites: {rgb: [1, 1, 1], master: 0.988, start: 0.34, width: 0.50}
          s_contrast: 1.00
  # NEW: Archival Extreme Matte — for “hard” matte scan vibe.
  - !<Look>
    name: Archival Extreme Matte
    process_space: ACEScct
    description: |
      Extreme matte archival: strong lifted blacks, very low chroma, soft shoulder, scan-heavy feel.
    transform: !<GroupTransform>
      children:
        - !<GradingPrimaryTransform>
          style: log
          contrast: {rgb: [1, 1, 1], master: 0.95}
          saturation: 0.80
        - !<GradingToneTransform>
          style: log
          blacks: {rgb: [1, 1, 1], master: 0.900, start: 0.32, width: 0.50}
          highlights: {rgb: [1, 1, 1], master: 0.960, start: 0.27, pivot: 0.88}
          whites: {rgb: [1, 1, 1], master: 0.975, start: 0.34, width: 0.50}
          s_contrast: 0.97
  - !<Look>
    name: Carbon Plate
    process_space: ACEScct
    description: |
      Dark editorial print body: velvet blacks, compressed mids, restrained chroma, soft highlight rolloff.
    transform: !<GroupTransform>
      children:
        - !<GradingPrimaryTransform>
          style: log
          contrast: {rgb: [1, 1, 1], master: 1.10}
          saturation: 0.82
        - !<GradingToneTransform>
          style: log
          blacks: {rgb: [1, 1, 1], master: 1.010, start: 0.33, width: 0.43}
          highlights: {rgb: [1, 1, 1], master: 0.988, start: 0.27, pivot: 0.90}
          whites: {rgb: [1, 1, 1], master: 0.995, start: 0.33, width: 0.43}
          s_contrast: 1.02
        - !<GradingRGBCurveTransform>
          style: log
          master: {control_points: [0, 0, 0.45, 0.395, 1, 1]}
  - !<Look>
    name: Carbon Black
    process_space: ACEScct
    description: |
      Near-black object-photo rendering with a preserved low-mid read band and restrained chroma.
    transform: !<GroupTransform>
      children:
        - !<GradingPrimaryTransform>
          style: log
          contrast: {rgb: [1, 1, 1], master: 1.13}
          saturation: 0.58
        - !<GradingToneTransform>
          style: log
          blacks: {rgb: [1, 1, 1], master: 1.030, start: 0.32, width: 0.40}
          highlights: {rgb: [1, 1, 1], master: 0.985, start: 0.27, pivot: 0.90}
          whites: {rgb: [1, 1, 1], master: 0.992, start: 0.32, width: 0.40}
          s_contrast: 1.03
        - !<GradingRGBCurveTransform>
          style: log
          master: {control_points: [0, 0, 0.10, 0.055, 0.22, 0.185, 1, 1]}
  - !<Look>
    name: Cold Steel Neutral
    process_space: ACEScct
    description: |
      Neutral-clean highlights with subtle cool steel bias confined to shadows.
    transform: !<GroupTransform>
      children:
        - !<GradingPrimaryTransform>
          style: log
          contrast: {rgb: [1, 1, 1], master: 1.04}
          saturation: 0.86
        - !<GradingToneTransform>
          style: log
          blacks: {rgb: [1, 1, 1], master: 1.000, start: 0.33, width: 0.44}
          highlights: {rgb: [1, 1, 1], master: 0.992, start: 0.27, pivot: 0.91}
          whites: {rgb: [1, 1, 1], master: 1.000, start: 0.33, width: 0.44}
          s_contrast: 1.00
        - !<GradingRGBCurveTransform>
          style: log
          red: {control_points: [0, 0, 0.28, 0.276, 1, 1]}
          blue: {control_points: [0, 0, 0.28, 0.284, 1, 1]}
          green: {control_points: [0, 0, 0.28, 0.281, 1, 1]}
  - !<Look>
    name: Vitrine
    process_space: ACEScct
    description: |
      Institutional display-case white: hostile clean field, compressed paper whites,
      heavier subject body, and reduced chroma with forensic clarity.
    transform: !<GroupTransform>
      children:
        - !<GradingPrimaryTransform>
          style: log
          contrast: {rgb: [1, 1, 1], master: 1.00}
          saturation: 0.74
        - !<GradingToneTransform>
          style: log
          blacks:     {rgb: [1, 1, 1], master: 1.020, start: 0.32, width: 0.40}
          highlights: {rgb: [1, 1, 1], master: 0.962, start: 0.24, pivot: 0.94}
          whites:     {rgb: [1, 1, 1], master: 1.008, start: 0.32, width: 0.40}
          s_contrast: 0.98
        - !<GradingRGBCurveTransform>
          style: log
          master: {control_points: [0, 0, 0.68, 0.668, 0.86, 0.840, 1, 0.984]}
          red:    {control_points: [0, 0, 0.82, 0.818, 1, 0.995]}
          blue:   {control_points: [0, 0, 0.82, 0.826, 1, 1]}
        - !<CDLTransform>
          {slope: [0.998, 1.000, 1.006], offset: [0.0005, 0.0005, 0.0010], power: [1.014, 1.014, 1.018], sat: 0.92}
  - !<Look>
    name: Museum Varnish
    process_space: ACEScct
    description: |
      Lacquered editorial object-photo rendering: polished highs, dense low-mids,
      ambered specular warmth, and compressed glossy separation.
    transform: !<GroupTransform>
      children:
        - !<GradingPrimaryTransform>
          style: log
          contrast: {rgb: [1, 1, 1], master: 1.10}
          saturation: 0.82
        - !<GradingToneTransform>
          style: log
          blacks:     {rgb: [1, 1, 1], master: 1.008, start: 0.33, width: 0.40}
          highlights: {rgb: [1, 1, 1], master: 0.968, start: 0.29, pivot: 0.94}
          whites:     {rgb: [1, 1, 1], master: 0.988, start: 0.33, width: 0.40}
          s_contrast: 1.03
        - !<GradingRGBCurveTransform>
          style: log
          red:    {control_points: [0, 0, 0.76, 0.772, 1, 1]}
          green:  {control_points: [0, 0, 0.76, 0.762, 1, 0.996]}
          blue:   {control_points: [0, 0, 0.76, 0.744, 1, 0.986]}
          master: {control_points: [0, 0, 0.82, 0.792, 1, 0.978]}
        - !<CDLTransform>
          {slope: [1.012, 1.000, 0.982], offset: [0.0000, 0.0000, 0.0000], power: [0.986, 0.992, 1.012], sat: 1.03}
  - !<Look>
    name: Chemical Drift
    process_space: ACEScct
    description: |
      Broken photochemical drift: dirty yellow-green lows, weak cyan-blue whites,
      compressed shoulder, and visibly unstable dye behavior.
    transform: !<GroupTransform>
      children:
        - !<GradingPrimaryTransform>
          style: log
          contrast: {rgb: [1, 1, 1], master: 1.00}
          saturation: 0.78
        - !<GradingToneTransform>
          style: log
          blacks:     {rgb: [1, 1, 1], master: 0.945, start: 0.33, width: 0.54}
          highlights: {rgb: [1, 1, 1], master: 0.952, start: 0.25, pivot: 0.86}
          whites:     {rgb: [1, 1, 1], master: 0.970, start: 0.33, width: 0.54}
          s_contrast: 0.98
        - !<GradingRGBCurveTransform>
          style: log
          red:   {control_points: [0, 0, 0.16, 0.182, 0.68, 0.690, 1, 0.986]}
          green: {control_points: [0, 0, 0.16, 0.176, 0.68, 0.708, 1, 0.992]}
          blue:  {control_points: [0, 0, 0.16, 0.158, 0.68, 0.732, 1, 1]}
        - !<CDLTransform>
          {slope: [1.014, 1.000, 0.978], offset: [0.0030, 0.0020, 0.0040], power: [1.028, 0.996, 0.970], sat: 0.90}
  - !<Look>
    name: Chemical Drift (CDL Reactivated)
    process_space: ACEScct
    description: |
      Chemical Drift with an ACEScg-linear CDL pre-pass before the ACEScct shaping stack.
      Keeps the drift identity while preserving your upstream node behavior.
    transform: !<GroupTransform>
      children:
        - !<ColorSpaceTransform> {src: ACEScct, dst: ACEScg}
        - !<CDLTransform>
          {slope: [1.06, 0.92, 0.92], offset: [0.019, -0.005, 0.005], power: [1.06, 0.98, 1.04], sat: 1.78}
        - !<ColorSpaceTransform> {src: ACEScg, dst: ACEScct}
        - !<GradingPrimaryTransform>
          style: log
          contrast: {rgb: [1, 1, 1], master: 1.00}
          saturation: 0.78
        - !<GradingToneTransform>
          style: log
          blacks:     {rgb: [1, 1, 1], master: 0.945, start: 0.33, width: 0.54}
          highlights: {rgb: [1, 1, 1], master: 0.952, start: 0.25, pivot: 0.86}
          whites:     {rgb: [1, 1, 1], master: 0.970, start: 0.33, width: 0.54}
          s_contrast: 0.98
        - !<GradingRGBCurveTransform>
          style: log
          red:   {control_points: [0, 0, 0.16, 0.182, 0.68, 0.690, 1, 0.986]}
          green: {control_points: [0, 0, 0.16, 0.176, 0.68, 0.708, 1, 0.992]}
          blue:  {control_points: [0, 0, 0.16, 0.158, 0.68, 0.732, 1, 1]}
        - !<CDLTransform>
          {slope: [1.014, 1.000, 0.978], offset: [0.0030, 0.0020, 0.0040], power: [1.028, 0.996, 0.970], sat: 0.90}
  - !<Look>
    name: Phoenix Drift
    process_space: ACEScct
    description: |
      Distinct broken-film print feel: hot yellow-red highs, cyan-blue shadow pollution,
      weak neutrality, contaminated floor, and obvious medium character.
    transform: !<GroupTransform>
      children:
        - !<GradingPrimaryTransform>
          style: log
          contrast: {rgb: [1, 1, 1], master: 1.03}
          saturation: 0.88
        - !<GradingToneTransform>
          style: log
          blacks:     {rgb: [1, 1, 1], master: 0.948, start: 0.34, width: 0.54}
          highlights: {rgb: [1, 1, 1], master: 0.958, start: 0.25, pivot: 0.86}
          whites:     {rgb: [1, 1, 1], master: 0.974, start: 0.34, width: 0.54}
          s_contrast: 0.99
        - !<GradingRGBCurveTransform>
          style: log
          red:   {control_points: [0, 0, 0.16, 0.170, 0.70, 0.724, 1, 1]}
          green: {control_points: [0, 0, 0.16, 0.168, 0.70, 0.706, 1, 0.992]}
          blue:  {control_points: [0, 0, 0.16, 0.150, 0.70, 0.742, 1, 0.984]}
        - !<CDLTransform>
          {slope: [1.026, 1.006, 0.964], offset: [0.0040, 0.0020, 0.0060], power: [1.018, 0.996, 0.956], sat: 0.96}
  - !<Look>
    name: Patent Black
    process_space: ACEScct
    description: |
      Wet-black editorial: preserves shadow readability while giving dark speculars a lacquered, slightly compressed highlight rolloff.
      Designed for leather, coated metal, glossy black product on dark backgrounds.
    transform: !<GroupTransform>
      children:
        - !<GradingPrimaryTransform>
          style: log
          contrast: {rgb: [1, 1, 1], master: 1.06}
          saturation: 0.85
        - !<GradingToneTransform>
          style: log
          blacks:     {rgb: [1, 1, 1], master: 1.000, start: 0.33, width: 0.44}
          highlights: {rgb: [1, 1, 1], master: 0.982, start: 0.30, pivot: 0.92}
          whites:     {rgb: [1, 1, 1], master: 0.996, start: 0.33, width: 0.44}
          s_contrast: 1.01
        - !<GradingRGBCurveTransform>
          style: log
          master: {control_points: [0, 0, 0.80, 0.785, 1, 0.985]}
  - !<Look>
    name: Editorial Split
    process_space: ACEScct
    description: |
      Editorial warm-high / cool-low split with restrained magnitude.
      Keeps highlight warmth (reds stay hot) while giving shadows a steel undertone.
      Not teal/orange; designed for premium editorial separation.
    transform: !<GroupTransform>
      children:
        - !<GradingPrimaryTransform>
          style: log
          contrast: {rgb: [1, 1, 1], master: 1.06}
          saturation: 0.92
        - !<GradingToneTransform>
          style: log
          blacks:     {rgb: [1, 1, 1], master: 1.006, start: 0.33, width: 0.44}
          highlights: {rgb: [1, 1, 1], master: 0.992, start: 0.27, pivot: 0.91}
          whites:     {rgb: [1, 1, 1], master: 1.000, start: 0.33, width: 0.44}
          s_contrast: 1.01
        - !<GradingRGBCurveTransform>
          style: log
          red: {control_points: [0, 0, 0.28, 0.275, 1, 1]}
          blue: {control_points: [0, 0, 0.28, 0.285, 1, 1]}
          green: {control_points: [0, 0, 0.28, 0.281, 1, 1]}
        - !<GradingRGBCurveTransform>
          style: log
          red: {control_points: [0, 0, 0.78, 0.784, 1, 1]}
          blue: {control_points: [0, 0, 0.78, 0.776, 1, 1]}
  - !<Look>
    name: Editorial Split (CDL Stack)
    process_space: ACEScct
    description: |
      Editorial Split with the three ACEScg-linear CDL nodes applied first.
    transform: !<GroupTransform>
      children:
        - !<ColorSpaceTransform> {src: ACEScct, dst: ACEScg}
        - !<CDLTransform> {slope: [3.3, 3.3, 3.3], offset: [0.0, 0.0, 0.0], power: [1.2, 1.2, 1.2], sat: 1}
        - !<CDLTransform> {slope: [2.0, 2.0, 2.0], offset: [0.008, 0.008, 0.008], power: [1.6, 1.6, 1.6], sat: 1}
        - !<CDLTransform> {slope: [1.88, 1.88, 1.88], offset: [0.0, 0.0, 0.0], power: [1.32, 1.32, 1.32], sat: 1}
        - !<ColorSpaceTransform> {src: ACEScg, dst: ACEScct}
        - !<LookTransform> {src: ACEScct, dst: ACEScct, looks: "Editorial Split"}
  - !<Look>
    name: Archival Warm-Gray (CDL Stack)
    process_space: ACEScct
    description: |
      Archival Warm-Gray with the three ACEScg-linear CDL nodes applied first.
    transform: !<GroupTransform>
      children:
        - !<ColorSpaceTransform> {src: ACEScct, dst: ACEScg}
        - !<CDLTransform> {slope: [3.3, 3.3, 3.3], offset: [0.0, 0.0, 0.0], power: [1.2, 1.2, 1.2], sat: 1}
        - !<CDLTransform> {slope: [2.0, 2.0, 2.0], offset: [0.008, 0.008, 0.008], power: [1.6, 1.6, 1.6], sat: 1}
        - !<CDLTransform> {slope: [1.88, 1.88, 1.88], offset: [0.0, 0.0, 0.0], power: [1.32, 1.32, 1.32], sat: 1}
        - !<ColorSpaceTransform> {src: ACEScg, dst: ACEScct}
        - !<LookTransform> {src: ACEScct, dst: ACEScct, looks: "Archival Warm-Gray"}
  - !<Look>
    name: Film Dense (CDL Stack)
    process_space: ACEScct
    description: |
      Film Dense with the three ACEScg-linear CDL nodes applied first.
    transform: !<GroupTransform>
      children:
        - !<ColorSpaceTransform> {src: ACEScct, dst: ACEScg}
        - !<CDLTransform> {slope: [3.3, 3.3, 3.3], offset: [0.0, 0.0, 0.0], power: [1.2, 1.2, 1.2], sat: 1}
        - !<CDLTransform> {slope: [2.0, 2.0, 2.0], offset: [0.008, 0.008, 0.008], power: [1.6, 1.6, 1.6], sat: 1}
        - !<CDLTransform> {slope: [1.88, 1.88, 1.88], offset: [0.0, 0.0, 0.0], power: [1.32, 1.32, 1.32], sat: 1}
        - !<ColorSpaceTransform> {src: ACEScg, dst: ACEScct}
        - !<LookTransform> {src: ACEScct, dst: ACEScct, looks: "Film Dense"}
  - !<Look>
    name: Photochemical (CDL Stack)
    process_space: ACEScct
    description: |
      Photochemical with the three ACEScg-linear CDL nodes applied first.
    transform: !<GroupTransform>
      children:
        - !<ColorSpaceTransform> {src: ACEScct, dst: ACEScg}
        - !<CDLTransform> {slope: [3.3, 3.3, 3.3], offset: [0.0, 0.0, 0.0], power: [1.2, 1.2, 1.2], sat: 1}
        - !<CDLTransform> {slope: [2.0, 2.0, 2.0], offset: [0.008, 0.008, 0.008], power: [1.6, 1.6, 1.6], sat: 1}
        - !<CDLTransform> {slope: [1.88, 1.88, 1.88], offset: [0.0, 0.0, 0.0], power: [1.32, 1.32, 1.32], sat: 1}
        - !<ColorSpaceTransform> {src: ACEScg, dst: ACEScct}
        - !<LookTransform> {src: ACEScct, dst: ACEScct, looks: "Photochemical"}
  - !<Look>
    name: Chemical Drift (CDL Stack)
    process_space: ACEScct
    description: |
      Chemical Drift with the three ACEScg-linear CDL nodes applied first.
    transform: !<GroupTransform>
      children:
        - !<ColorSpaceTransform> {src: ACEScct, dst: ACEScg}
        - !<CDLTransform> {slope: [3.3, 3.3, 3.3], offset: [0.0, 0.0, 0.0], power: [1.2, 1.2, 1.2], sat: 1}
        - !<CDLTransform> {slope: [2.0, 2.0, 2.0], offset: [0.008, 0.008, 0.008], power: [1.6, 1.6, 1.6], sat: 1}
        - !<CDLTransform> {slope: [1.88, 1.88, 1.88], offset: [0.0, 0.0, 0.0], power: [1.32, 1.32, 1.32], sat: 1}
        - !<ColorSpaceTransform> {src: ACEScg, dst: ACEScct}
        - !<LookTransform> {src: ACEScct, dst: ACEScct, looks: "Chemical Drift"}
  - !<Look>
    name: Phoenix Drift (CDL Stack)
    process_space: ACEScct
    description: |
      Phoenix Drift with the three ACEScg-linear CDL nodes applied first.
