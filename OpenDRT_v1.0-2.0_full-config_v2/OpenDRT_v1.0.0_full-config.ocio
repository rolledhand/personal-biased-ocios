    allocation: lg2
    allocationvars: [-8, 8, 0.01]
    to_reference: !<MatrixTransform> {matrix: [0.860364559109989, 0.093477087319336, 0.0461583535706745, 0, 0.0649966005316538, 0.952140905872229, -0.0171375064038824, 0, 0.0725027295211905, 0.00879147325623128, 0.918705797222578, 0, 0, 0, 0, 1]}

