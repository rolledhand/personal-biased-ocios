    allocationvars: [-8, 8, 0.01]
    to_reference: !<MatrixTransform> {matrix: [0.952171979210153, 0.0478280207898475, -2.77555756156289e-17, 0, 0.0235856774256269, 0.976414322574374, -2.77555756156289e-17, 0, 0.0127325271065867, 0.0139477362987688, 0.973319736594645, 0, 0, 0, 0, 1]}

