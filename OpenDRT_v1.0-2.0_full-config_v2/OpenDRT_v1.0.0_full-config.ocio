      S-2016-001 : ACEScct — A Quasi-Logarithmic Encoding of ACES Data for use within Color Grading Systems
      http://j.mp/S-2016-001_
    to_reference: !<GroupTransform>
      children:
        - !<FileTransform> {src: oetf_acescct_to_linear.spi1d, interpolation: linear}
        - !<ColorSpaceTransform> {src: ACEScg, dst: reference}

  - !<ColorSpace>
    name: Filmlight - E-Gamut - Linear
    family: Working Spaces
