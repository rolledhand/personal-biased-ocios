ocio_profile_version: 1

search_path: luts:transfer_functions
strictparsing: true
luma: [0.2126, 0.7152, 0.0722]
description: |
  The OpenDRT OCIO config: https://github.com/jedypod/open-display-transform
  Generated with ociogen: https://github.com/jedypod/ociogen
  This OCIO Config and the associated spi1d and cube LUT files are licensed
  permissively under the MIT License. See LICENSE.md for details.

  Release v2 - 20250410
    - Fix missing ACES 2065-1 colorspace.
  Release v1 - 20250406
    - Initial release.
  

roles:
  color_picking: Filmlight - E-Gamut2 - Linear
  color_timing: Filmlight - E-Gamut2 - T-Log
  compositing_linear: Filmlight - E-Gamut2 - Linear
  compositing_log: Filmlight - E-Gamut2 - T-Log
  data: Filmlight - E-Gamut2 - Linear
  default: Filmlight - E-Gamut2 - Linear
  matte_paint: Filmlight - E-Gamut2 - T-Log
  reference: Filmlight - E-Gamut2 - Linear
  scene_linear: Filmlight - E-Gamut2 - Linear
  texture_paint: Filmlight - E-Gamut2 - Linear


displays:
  Rec.1886:
    - !<View> {name: OpenDRT v1.0.0 Default, colorspace: OpenDRT v1.0.0 Default - Rec.1886}
    - !<View> {name: OpenDRT v1.0.0 Colorful, colorspace: OpenDRT v1.0.0 Colorful - Rec.1886}
    - !<View> {name: OpenDRT v1.0.0 Umbra, colorspace: OpenDRT v1.0.0 Umbra - Rec.1886}
    - !<View> {name: Display Encoding, colorspace: Rec.1886}
    - !<View> {name: Bypass, colorspace: bypass}
  Display P3:
    - !<View> {name: OpenDRT v1.0.0 Default, colorspace: OpenDRT v1.0.0 Default - Display P3}
    - !<View> {name: OpenDRT v1.0.0 Colorful, colorspace: OpenDRT v1.0.0 Colorful - Display P3}
    - !<View> {name: OpenDRT v1.0.0 Umbra, colorspace: OpenDRT v1.0.0 Umbra - Display P3}
    - !<View> {name: Display Encoding, colorspace: Display P3}
    - !<View> {name: Bypass, colorspace: bypass}
  Rec2100 PQ:
    - !<View> {name: OpenDRT v1.0.0 Default, colorspace: OpenDRT v1.0.0 Default - Rec2100 PQ}
    - !<View> {name: OpenDRT v1.0.0 Colorful, colorspace: OpenDRT v1.0.0 Colorful - Rec2100 PQ}
    - !<View> {name: OpenDRT v1.0.0 Umbra, colorspace: OpenDRT v1.0.0 Umbra - Rec2100 PQ}
    - !<View> {name: Display Encoding, colorspace: Rec2100 PQ}
    - !<View> {name: Bypass, colorspace: bypass}
  sRGB Display:
    - !<View> {name: OpenDRT v1.0.0 Default, colorspace: OpenDRT v1.0.0 Default - sRGB Display}
    - !<View> {name: OpenDRT v1.0.0 Colorful, colorspace: OpenDRT v1.0.0 Colorful - sRGB Display}
    - !<View> {name: OpenDRT v1.0.0 Umbra, colorspace: OpenDRT v1.0.0 Umbra - sRGB Display}
    - !<View> {name: Display Encoding, colorspace: sRGB Display}
    - !<View> {name: Bypass, colorspace: bypass}

active_displays: [Rec.1886, Display P3, Rec2100 PQ, sRGB Display]
active_views: [OpenDRT v1.0.0 Default, OpenDRT v1.0.0 Colorful, OpenDRT v1.0.0 Umbra, Display Encoding, Bypass]

colorspaces:
  - !<ColorSpace>
    name: bypass
    family: Working Spaces
    description: Non-Color Data
    allocation: lg2
    allocationvars: [-8, 8, 0.01]

  - !<ColorSpace>
    name: XYZ D65
    family: Working Spaces
    description: Linear CIE XYZ adapted to the Illuminant D65 whitepoint
    allocation: lg2
    allocationvars: [-8, 8, 0.01]
    to_reference: !<MatrixTransform> {matrix: [1.35702367254585, -0.237033581941448, -0.119990090604401, 0, -0.438325988676953, 1.29442894440374, 0.143897044273212, 0, 0.100252080766426, 0.0641140083985013, 0.835633910835072, 0, 0, 0, 0, 1]}

  - !<ColorSpace>
    name: XYZ E
    family: Working Spaces
    description: Linear CIE XYZ adapted to the Illuminant E whitepoint
    allocation: lg2
    allocationvars: [-8, 8, 0.01]
    to_reference: !<MatrixTransform> {matrix: [1.38623731434911, -0.299319207576944, -0.0869181067721651, 0, -0.482617156491486, 1.33734391557841, 0.145273240913077, 0, 0.100663545792904, 0.0618669681169714, 0.837469486090125, 0, 0, 0, 0, 1]}

  - !<ColorSpace>
    name: ACES 2065-1
    family: Working Spaces
    allocation: lg2
    allocationvars: [-8, 8, 0.01]
    to_reference: !<MatrixTransform> {matrix: [1.25992122474977, -0.180662379244654, -0.0792588455051215, 0, 0.00486107030443775, 0.944082892223335, 0.0510560374722275, 0, 0.121236193720255, 0.0466469429928843, 0.83211686328686, 0, 0, 0, 0, 1]}

  - !<ColorSpace>
    name: ACEScg
    family: Working Spaces
    description: |
      Linear AP1 ACEScg
      S-2014-004 : ACEScg — A Working Space for CGI Render and Compositing
      http://j.mp/S-2014-004
    allocation: lg2
    allocationvars: [-8, 8, 0.01]
    to_reference: !<MatrixTransform> {matrix: [0.868560322361992, 0.0216148124030379, 0.10982486523497, 0, 0.0453882935158179, 0.812490156195302, 0.14212155028888, 0, 0.0818053320392553, 0.0605058247267323, 0.857688843234013, 0, 0, 0, 0, 1]}

