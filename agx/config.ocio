# OpenColorIO configuration file for Blender
#
# ACEScg and ACES2065-1 spaces using OpenColorIO's BuiltinTransform
#
# Based on original AgX by Troy Sobotka: https://github.com/sobotka/AgX https://github.com/sobotka/SB2383-Configuration-Generation
# Further Developed by Zijun Eary Zhou法纤净, Mark Faderbauer, and Sakari Kapanen
# Repository for this version: https://github.com/EaryChow/AgX
#
# See ocio-license.txt for details.

ocio_profile_version: 2.4

search_path: "luts"
strictparsing: true
luma: [0.2126, 0.7152, 0.0722]

description: RRT version ut33

roles:
  reference: Linear CIE-XYZ E

  # Internal scene linear space
  scene_linear: Linear Rec.2020
  rendering: Linear Rec.2020

  # Default color space for byte image
  default_byte: sRGB

  # Default color space for float images
  default_float: Linear Rec.2020

  # Default color space sequencer is working in
  default_sequencer: sRGB

  # Distribution of colors in color picker
  color_picking: sRGB

  # Non-color data
  data: Non-Color

  # For interop between configs, and to determine XYZ for rendering
  aces_interchange: ACES2065-1
  cie_xyz_d65_interchange: Linear CIE-XYZ D65

  # Specified by OCIO, not used in Blender
  color_timing: AgX Log
  compositing_linear: Linear Rec.2020
  compositing_log: AgX Log
  default: Linear Rec.2020
  matte_paint: Linear Rec.2020
  texture_paint: Linear Rec.2020

file_rules:
  - !<Rule> {name: houdini_raw_data, colorspace: Non-Color, regex: "(^|.*[._-])(raw|data|noncolor|non-color|utility-raw|mask|matte|alpha|opacity|rough(ness)?|gloss(y|iness)?|metal(ness|lic)?|specularlevel|ior|normal|nrm|bump|height|disp(lacement)?|ao|ambientocclusion|cavity)([._-].*|\\..*|$)"}
  - !<Rule> {name: houdini_aces2065_1, colorspace: ACES2065-1, regex: "(^|.*[._-])(aces2065[-_]?1|aces[-_]?ap0|lin[-_]?ap0)([._-].*|\\..*|$)"}
  - !<Rule> {name: houdini_acescg, colorspace: ACEScg, regex: "(^|.*[._-])(acescg|aces[-_]?cg|aces[-_]?ap1|lin[-_]?ap1)([._-].*|\\..*|$)"}
  - !<Rule> {name: houdini_lin_rec2020, colorspace: Linear Rec.2020, regex: "(^|.*[._-])(lin[-_]?rec2020|linear[-_]?rec2020|bt2020|rec2020|render[-_]?linear)([._-].*|\\..*|$)"}
  - !<Rule> {name: houdini_lin_rec709, colorspace: Linear Rec.709, regex: "(^|.*[._-])(lin[-_]?srgb|lin[-_]?rec709|linear[-_]?srgb|linear[-_]?rec709)([._-].*|\\..*|$)"}
  - !<Rule> {name: houdini_srgb_texture, colorspace: sRGB, regex: "(^|.*[._-])(srgb|srgb[-_]?tx|srgb[-_]?texture|basecolor|base[-_]?color|diffuse|diff|albedo|color|colour|col)([._-].*|\\..*|$)"}
  - !<Rule> {name: srgb_tx, colorspace: sRGB, pattern: "*srgb_tx*", extension: "*"}
  - !<Rule> {name: srgb_texture, colorspace: sRGB, pattern: "*srgb_texture*", extension: "*"}
  - !<Rule> {name: acescg, colorspace: ACEScg, pattern: "*ACEScg*", extension: "*"}
  - !<Rule> {name: acescg_lower, colorspace: ACEScg, pattern: "*acescg*", extension: "*"}
  - !<Rule> {name: lin_rec2020, colorspace: Linear Rec.2020, pattern: "*lin_rec2020*", extension: "*"}
  - !<Rule> {name: linear_rec2020, colorspace: Linear Rec.2020, pattern: "*linear_rec2020*", extension: "*"}
  - !<Rule> {name: lin_rec709, colorspace: Linear Rec.709, pattern: "*lin_rec709*", extension: "*"}
  - !<Rule> {name: lin_srgb, colorspace: Linear Rec.709, pattern: "*lin_srgb*", extension: "*"}
  - !<Rule> {name: rat, colorspace: Linear Rec.2020, pattern: "*", extension: rat}
  - !<Rule> {name: hdr, colorspace: Linear Rec.2020, pattern: "*", extension: hdr}
  - !<Rule> {name: jpg, colorspace: sRGB, pattern: "*", extension: jpg}
  - !<Rule> {name: jpeg, colorspace: sRGB, pattern: "*", extension: jpeg}
  - !<Rule> {name: png, colorspace: sRGB, pattern: "*", extension: png}
  - !<Rule> {name: tga, colorspace: sRGB, pattern: "*", extension: tga}
  - !<Rule> {name: bmp, colorspace: sRGB, pattern: "*", extension: bmp}
  - !<Rule> {name: tif, colorspace: sRGB, pattern: "*", extension: tif}
  - !<Rule> {name: tiff, colorspace: sRGB, pattern: "*", extension: tiff}
  - !<Rule> {name: exr, colorspace: Linear Rec.2020, pattern: "*", extension: exr}
  - !<Rule> {name: Default, colorspace: Linear Rec.2020}

displays:
  sRGB:
    - !<View> {name: Un-tone-mapped, view_transform: Un-tone-mapped, display_colorspace: sRGB}
    - !<View> {name: AgX, view_transform: AgX Base Rec.1886, display_colorspace: sRGB}
    - !<View> {name: AgX - Editorial Split, view_transform: AgX Base Rec.1886, display_colorspace: sRGB, looks: "Editorial Split"}
    - !<View> {name: AgX - Editorial Split (CDL Stack), view_transform: AgX Base Rec.1886, display_colorspace: sRGB, looks: "Editorial Split (CDL Stack)"}
    - !<View> {name: AgX - Graphite Matte, view_transform: AgX Base Rec.1886, display_colorspace: sRGB, looks: "Graphite Matte"}
    - !<View> {name: AgX - Graphite Matte (CDL Shift), view_transform: AgX Base Rec.1886, display_colorspace: sRGB, looks: "Graphite Matte (CDL Shift)"}
    - !<View> {name: AgX - Graphite Matte (CDL Shift 2), view_transform: AgX Base Rec.1886, display_colorspace: sRGB, looks: "Graphite Matte (CDL Shift 2)"}
    - !<View> {name: AgX - Cold Steel Neutral, view_transform: AgX Base Rec.1886, display_colorspace: sRGB, looks: "Cold Steel Neutral"}
    - !<View> {name: AgX - Carbon Black, view_transform: AgX Base Rec.1886, display_colorspace: sRGB, looks: "Carbon Black"}
    - !<View> {name: AgX - Carbon Black (CDL Shift 2), view_transform: AgX Base Rec.1886, display_colorspace: sRGB, looks: "Carbon Black (CDL Shift 2)"}
    - !<View> {name: AgX - Carbon Plate, view_transform: AgX Base Rec.1886, display_colorspace: sRGB, looks: "Carbon Plate"}
    - !<View> {name: AgX - Carbon Plate (CDL Shift), view_transform: AgX Base Rec.1886, display_colorspace: sRGB, looks: "Carbon Plate (CDL Shift)"}
    - !<View> {name: AgX - Archival Warm-Gray, view_transform: AgX Base Rec.1886, display_colorspace: sRGB, looks: "Archival Warm-Gray"}
    - !<View> {name: AgX - Archival Warm-Gray (CDL Shift), view_transform: AgX Base Rec.1886, display_colorspace: sRGB, looks: "Archival Warm-Gray (CDL Shift)"}
    - !<View> {name: AgX - Archival Warm-Gray (CDL Shift 2), view_transform: AgX Base Rec.1886, display_colorspace: sRGB, looks: "Archival Warm-Gray (CDL Shift 2)"}
    - !<View> {name: AgX - Archival Warm-Gray (CDL Stack), view_transform: AgX Base Rec.1886, display_colorspace: sRGB, looks: "Archival Warm-Gray (CDL Stack)"}
    - !<View> {name: AgX - Archival Extreme Matte (CDL Matte Fade), view_transform: AgX Base Rec.1886, display_colorspace: sRGB, looks: "Archival Extreme Matte (CDL Matte Fade)"}
    - !<View> {name: AgX - Film Dense, view_transform: AgX Base Rec.1886, display_colorspace: sRGB, looks: "Film Dense"}
    - !<View> {name: AgX - Film Dense (CDL Shift), view_transform: AgX Base Rec.1886, display_colorspace: sRGB, looks: "Film Dense (CDL Shift)"}
    - !<View> {name: AgX - Film Dense (CDL Stack), view_transform: AgX Base Rec.1886, display_colorspace: sRGB, looks: "Film Dense (CDL Stack)"}
    - !<View> {name: AgX - Photochemical, view_transform: AgX Base Rec.1886, display_colorspace: sRGB, looks: "Photochemical"}
    - !<View> {name: AgX - Photochemical (CDL Shift), view_transform: AgX Base Rec.1886, display_colorspace: sRGB, looks: "Photochemical (CDL Shift)"}
    - !<View> {name: AgX - Photochemical (CDL Shift 2), view_transform: AgX Base Rec.1886, display_colorspace: sRGB, looks: "Photochemical (CDL Shift 2)"}
