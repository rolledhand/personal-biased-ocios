    - !<View> {name: AgX - Chemical Drift (CDL Shift 2), view_transform: AgX Base Rec.1886, display_colorspace: sRGB, looks: "Chemical Drift (CDL Shift 2)"}
    - !<View> {name: AgX - Chemical Drift (CDL Stack), view_transform: AgX Base Rec.1886, display_colorspace: sRGB, looks: "Chemical Drift (CDL Stack)"}
    - !<View> {name: AgX - Phoenix Drift, view_transform: AgX Base Rec.1886, display_colorspace: sRGB, looks: "Phoenix Drift"}
    - !<View> {name: AgX - Phoenix Drift (CDL Shift), view_transform: AgX Base Rec.1886, display_colorspace: sRGB, looks: "Phoenix Drift (CDL Shift)"}
    - !<View> {name: AgX - Phoenix Drift (CDL Shift 2), view_transform: AgX Base Rec.1886, display_colorspace: sRGB, looks: "Phoenix Drift (CDL Shift 2)"}
