active_views: [Un-tone-mapped, AgX, AgX - HDR 1000 nits, AgX - SDR, AgX - Editorial Split, AgX - Editorial Split (CDL Stack), AgX - Graphite Matte, AgX - Graphite Matte (CDL Shift), AgX - Graphite Matte (CDL Shift 2), AgX - Cold Steel Neutral, AgX - Carbon Black, AgX - Carbon Black (CDL Shift 2), AgX - Carbon Plate, AgX - Carbon Plate (CDL Shift), AgX - Archival Warm-Gray, AgX - Archival Warm-Gray (CDL Shift), AgX - Archival Warm-Gray (CDL Shift 2), AgX - Archival Warm-Gray (CDL Stack), AgX - Archival Extreme Matte (CDL Matte Fade), AgX - Film Dense, AgX - Film Dense (CDL Shift), AgX - Film Dense (CDL Stack), AgX - Photochemical, AgX - Photochemical (CDL Shift), AgX - Photochemical (CDL Shift 2), AgX - Photochemical (CDL Stack), AgX - Vitrine, AgX - Vitrine (CDL Shift 2), AgX - Chemical Drift, AgX - Chemical Drift (CDL Shift 2), AgX - Chemical Drift (CDL Stack), AgX - Phoenix Drift, AgX - Phoenix Drift (CDL Shift), AgX - Phoenix Drift (CDL Shift 2), AgX - Phoenix Drift (CDL Stack), AgX HDR - Editorial Split, AgX HDR - Editorial Split (CDL Stack), AgX HDR - Graphite Matte, AgX HDR - Graphite Matte (CDL Shift), AgX HDR - Graphite Matte (CDL Shift 2), AgX HDR - Cold Steel Neutral, AgX HDR - Carbon Black, AgX HDR - Carbon Black (CDL Shift 2), AgX HDR - Carbon Plate, AgX HDR - Carbon Plate (CDL Shift), AgX HDR - Archival Warm-Gray, AgX HDR - Archival Warm-Gray (CDL Shift), AgX HDR - Archival Warm-Gray (CDL Shift 2), AgX HDR - Archival Warm-Gray (CDL Stack), AgX HDR - Archival Extreme Matte (CDL Matte Fade), AgX HDR - Film Dense, AgX HDR - Film Dense (CDL Shift), AgX HDR - Film Dense (CDL Stack), AgX HDR - Photochemical, AgX HDR - Photochemical (CDL Shift), AgX HDR - Photochemical (CDL Shift 2), AgX HDR - Photochemical (CDL Stack), AgX HDR - Vitrine, AgX HDR - Vitrine (CDL Shift 2), AgX HDR - Chemical Drift, AgX HDR - Chemical Drift (CDL Shift 2), AgX HDR - Chemical Drift (CDL Stack), AgX HDR - Phoenix Drift, AgX HDR - Phoenix Drift (CDL Shift), AgX HDR - Phoenix Drift (CDL Shift 2), AgX HDR - Phoenix Drift (CDL Stack), AgX SDR - Editorial Split, AgX SDR - Editorial Split (CDL Stack), AgX SDR - Graphite Matte, AgX SDR - Graphite Matte (CDL Shift), AgX SDR - Graphite Matte (CDL Shift 2), AgX SDR - Cold Steel Neutral, AgX SDR - Carbon Black, AgX SDR - Carbon Black (CDL Shift 2), AgX SDR - Carbon Plate, AgX SDR - Carbon Plate (CDL Shift), AgX SDR - Archival Warm-Gray, AgX SDR - Archival Warm-Gray (CDL Shift), AgX SDR - Archival Warm-Gray (CDL Shift 2), AgX SDR - Archival Warm-Gray (CDL Stack), AgX SDR - Archival Extreme Matte (CDL Matte Fade), AgX SDR - Film Dense, AgX SDR - Film Dense (CDL Shift), AgX SDR - Film Dense (CDL Stack), AgX SDR - Photochemical, AgX SDR - Photochemical (CDL Shift), AgX SDR - Photochemical (CDL Shift 2), AgX SDR - Photochemical (CDL Stack), AgX SDR - Vitrine, AgX SDR - Vitrine (CDL Shift 2), AgX SDR - Chemical Drift, AgX SDR - Chemical Drift (CDL Shift 2), AgX SDR - Chemical Drift (CDL Stack), AgX SDR - Phoenix Drift, AgX SDR - Phoenix Drift (CDL Shift), AgX SDR - Phoenix Drift (CDL Shift 2), AgX SDR - Phoenix Drift (CDL Stack)]
inactive_colorspaces: [Luminance Compensation Rec.2020]

display_colorspaces:
  - !<ColorSpace>
    name: Linear CIE-XYZ D65
    aliases: [lin_ciexyzd65_scene, cie_xyz_d65, CIE-XYZ-D65, XYZ, Linear CIE-XYZ I-D65]
    family: Chromaticity
    equalitygroup:
    bitdepth: 32f
    description: |
      1931 CIE XYZ with adapted illuminant D65 white point
    isdata: false
    encoding: display-linear

  - !<ColorSpace>
    name: sRGB
    aliases: [srgb, srgb8, srgb_rec709_display, srgb_rec709_scene, sRGB 2.2, sRGB I-D65, srgb_display, sRGB - Display, g22_rec709, Utility - Gamma 2.2 - Rec.709 - Texture, Utility - sRGB - Texture, sRGB - Texture, srgb_tx, srgb_texture, Input - Generic - sRGB - Texture, texture_srgb, basecolor_srgb, albedo_srgb, "sRGB Display: 2.2 Gamma - Rec.709"]
    family: Display
    equalitygroup:
    bitdepth: 32f
    description: |
      sRGB IEC 61966-2-1 compound (piece-wise) encoding
    isdata: false
    from_display_reference: !<GroupTransform>
      children:
        - !<ColorSpaceTransform> {src: cie_xyz_d65_interchange, dst: Linear Rec.709}
        - !<ExponentWithLinearTransform> {gamma: 2.4, offset: 0.055, direction: inverse}

  - !<ColorSpace>
    name: Display P3
    aliases: [srgb_p3d65_display, srgb_p3d65_scene, Display P3 2.2, Display P3 I-D65, P3-D65 - Display, p3_d65_display, p3d65_display, AppleP3 sRGB OETF]
    family: Display
    equalitygroup:
    bitdepth: 32f
    description: |
      Apple's Display P3 with sRGB compound (piece-wise) encoding transfer function, common on Mac devices
    isdata: false
    from_display_reference: !<GroupTransform>
      children:
        - !<ColorSpaceTransform> {src: cie_xyz_d65_interchange, dst: Linear DCI-P3 D65}
        - !<ExponentWithLinearTransform> {gamma: 2.4, offset: 0.055, direction: inverse}

  - !<ColorSpace>
    name: Rec.1886
    aliases: [g24_rec709_display, BT.1886, BT.1886 2.4, BT.1886 EOTF, BT.1886 I-D65, Rec.1886 / Rec.709 Video - Display, rec1886_rec709_display, rec1886_rec709_video_display, Rec.1886 Rec.709 - Display, "Rec1886: 2.4 Gamma - Rec.709"]
    family: Display
    equalitygroup:
    bitdepth: 32f
    description: |
      BT.1886 2.4 Exponent EOTF Display, commonly used for TVs
    isdata: false
    from_display_reference: !<GroupTransform>
      children:
        - !<ColorSpaceTransform> {src: cie_xyz_d65_interchange, dst: Linear Rec.709}
        - !<ExponentTransform> {value: 2.4, direction: inverse}

  - !<ColorSpace>
    name: Rec.2020
    aliases: [g24_rec2020_display, BT.2020, BT.2020 2.4, BT.2020 I-D65, Rec.1886 / Rec.2020 Video - Display, rec1886_rec2020_display, rec1886_rec2020_video_display, Rec.1886 Rec.2020 - Display, "Rec1886: 2.4 Gamma - Rec.2020"]
    family: Display
    equalitygroup:
    bitdepth: 32f
    description: |
      BT.2020 2.4 Exponent EOTF Display
    isdata: false
    from_display_reference: !<GroupTransform>
      children:
        - !<ColorSpaceTransform> {src: cie_xyz_d65_interchange, dst: Linear Rec.2020}
        - !<ExponentTransform> {value: 2.4, direction: inverse}

  - !<ColorSpace>
    name: Rec.2100-PQ
    aliases: [pq_rec2020_display, rec2100_pq_display, Rec.2100-PQ - Display]
    family: Display
    equalitygroup: ""
    bitdepth: 32f
    description: Rec.2100-PQ 10000 nits peak display with reference white at 100 nits
    isdata: false
    encoding: hdr-video
    allocation: uniform
    from_display_reference: !<GroupTransform>
      children:
        - !<BuiltinTransform> {style: DISPLAY - CIE-XYZ-D65_to_REC.2100-PQ}

  - !<ColorSpace>
    name: Rec.2100-HLG
    aliases: [hlg_rec2020_display, rec2100_hlg_display, Rec.2100-HLG - Display]
    family: Display
    equalitygroup: ""
    bitdepth: 32f
    description: Rec.2100-HLG 1000 nits peak display with reference white at 100 nits
    isdata: false
    encoding: hdr-video
    allocation: uniform
    from_display_reference: !<GroupTransform>
      children:
        - !<BuiltinTransform> {style: DISPLAY - CIE-XYZ-D65_to_REC.2100-HLG-1000nit}

  - !<ColorSpace>
    name: AgX Base sRGB
    family: AgX/Display
    description: |
      AgX Base Image Encoding for sRGB Display
    from_display_reference: !<GroupTransform>
      children:
        - !<ColorSpaceTransform> {src: cie_xyz_d65_interchange, dst: Linear FilmLight E-Gamut}
        - !<AllocationTransform> {allocation: lg2, vars: [-12.47393, 12.5260688117]}
        - !<FileTransform> {src: AgX_Base_sRGB.cube, interpolation: tetrahedral}
        - !<ColorSpaceTransform> {src: Rec.1886, dst: sRGB}
default_view_transform: Un-tone-mapped

view_transforms:
  - !<ViewTransform>
    name: Un-tone-mapped
    family: Un-tone-mapped
    description: Apply only the display's standard transform without additional mappings
    from_scene_reference: !<FileTransform> {src: xyz_E_to_D65.spimtx, interpolation: linear}

  - !<ViewTransform>
    name: AgX Base Rec.2020
    family: AgX
    description: |
      AgX Base Image Encoding for BT.2020 Display
    from_scene_reference: !<GroupTransform>
      children:
        - !<ColorSpaceTransform> {src: Linear CIE-XYZ E, dst: Linear FilmLight E-Gamut}
        - !<AllocationTransform> {allocation: lg2, vars: [-12.47393, 12.5260688117]}
        - !<FileTransform> {src: AgX_Base_Rec2020.cube, interpolation: tetrahedral}
        - !<ColorSpaceTransform> {src: Rec.2020, dst: cie_xyz_d65_interchange}

  - !<ViewTransform>
    name: AgX Base Rec.1886
    family: AgX
    description: |
      AgX Base Image Encoding for sRGB and Rec.1886 Display
    from_scene_reference: !<GroupTransform>
      children:
        - !<ColorSpaceTransform> {src: Linear CIE-XYZ E, dst: Linear FilmLight E-Gamut}
        - !<AllocationTransform> {allocation: lg2, vars: [-12.47393, 12.5260688117]}
        - !<FileTransform> {src: AgX_Base_sRGB.cube, interpolation: tetrahedral}
        - !<ColorSpaceTransform> {src: Rec.1886, dst: cie_xyz_d65_interchange}

  - !<ViewTransform>
    name: AgX Base Display P3
    family: AgX
    description: |
      AgX Base Image Encoding for Display P3 Display
    from_scene_reference: !<GroupTransform>
      children:
        - !<ColorSpaceTransform> {src: Linear CIE-XYZ E, dst: Linear FilmLight E-Gamut}
        - !<AllocationTransform> {allocation: lg2, vars: [-12.47393, 12.5260688117]}
        - !<FileTransform> {src: AgX_Base_P3.cube, interpolation: tetrahedral}
        - !<ExponentTransform> {value: 2.4}
        - !<ColorSpaceTransform> {src: Linear DCI-P3 D65, dst: cie_xyz_d65_interchange}

  - !<ViewTransform>
    name: AgX Rec.2100-HLG - HDR 1000 nits (P3 D65)
    family: AgX
    description: |
      AgX 1000 nits peak Image Encoding for BT.2100-HLG P3 limited Display. Reference white is 100nits
    from_scene_reference: !<GroupTransform>
      children:
        - !<ColorSpaceTransform> {src: Linear CIE-XYZ E, dst: Linear FilmLight E-Gamut}
        - !<AllocationTransform> {allocation: lg2, vars: [-12.47393, 12.5260688117]}
        - !<FileTransform> {src: AgX_Rec2100-HLG_p3_lim.cube, interpolation: tetrahedral}
        - !<ColorSpaceTransform> {src: Rec.2100-HLG, dst: cie_xyz_d65_interchange}
colorspaces:
  - !<ColorSpace>
    name: Linear CIE-XYZ E
    aliases: ["FilmLight: Linear - XYZ", Linear CIE-XYZ I-E]
    family: Chromaticity
    equalitygroup:
    bitdepth: 32f
    description: |
      1931 CIE XYZ standard with assumed illuminant E white point
    isdata: false

  - !<ColorSpace>
    name: Linear Rec.709
    aliases: [lin_rec709_scene, Linear, linear, Linear BT.709, Linear BT.709 I-D65, Linear Tristimulus, linrec709, Utility - Linear - sRGB, Utility - Linear - Rec.709, lin_srgb, Linear Rec.709 (sRGB), lin_rec709_srgb, lin_rec709, lin_srgb, "CGI: Linear - Rec.709"]
    family: Linear
    equalitygroup:
    bitdepth: 32f
    description: |
      Linear BT.709 with illuminant D65 white point
    isdata: false
    from_scene_reference: !<GroupTransform>
      children:
        - !<ColorSpaceTransform> {src: Linear CIE-XYZ E, dst: Linear CIE-XYZ D65}
        - !<MatrixTransform> {matrix: [3.2409699, -1.5373832, -0.4986108, 0, -0.9692436, 1.8759675, 0.0415551, 0, 0.0556301, -0.2039770, 1.0569715, 0, 0, 0, 0, 1]}

  - !<ColorSpace>
    name: Linear DCI-P3 D65
    aliases: [lin_p3d65_scene, Linear DCI-P3 I-D65, Linear P3-D65, lin_p3d65, Utility - Linear - P3-D65, Apple DCI-P3 D65]
    family: Linear
    equalitygroup:
    bitdepth: 32f
    description: |
      Linear DCI-P3 with illuminant D65 white point
    isdata: false
    from_scene_reference: !<GroupTransform>
      children:
        - !<ColorSpaceTransform> {src: Linear CIE-XYZ E, dst: Linear CIE-XYZ D65}
        - !<MatrixTransform> {matrix: [2.4934969, -0.9313836, -0.4027108, 0, -0.8294890, 1.7626641, 0.0236247, 0, 0.0358458, -0.0761724, 0.9568845, 0, 0, 0, 0, 1]}

  - !<ColorSpace>
    name: Linear Rec.2020
    aliases: [lin_rec2020_scene, Linear Rec.2020 I-D65, Linear BT.2020 I-D65, Linear BT.2020, BT.2020 Linear, Rec.2020 Linear, lin_rec2020, lin_bt2020, lin_rec2020_rendering, render_linear, Utility - Linear - Rec.2020]
    family: Linear
    equalitygroup:
    bitdepth: 32f
    description: |
      Linear BT.2020 with illuminant D65 white point
    isdata: false
    from_scene_reference: !<GroupTransform>
      children:
        - !<ColorSpaceTransform> {src: Linear CIE-XYZ E, dst: Linear CIE-XYZ D65}
        - !<MatrixTransform> {matrix: [1.7166512, -0.3556708, -0.2533663, 0, -0.6666844, 1.6164812, 0.0157685, 0, 0.0176399, -0.0427706, 0.9421031, 0, 0, 0, 0, 1]}

  - !<ColorSpace>
    name: ACES2065-1
    aliases: [lin_ap0_scene, lin_ap0, Linear ACES, aces2065-1, aces2065_1, aces, ACES, ACES AP0, aces_ap0, ACES - ACES2065-1, "ACES: Linear - AP0"]
    family: ACES
    equalitygroup:
    bitdepth: 32f
    description: |
      Linear AP0 with ACES white point
    isdata: false
    from_scene_reference: !<GroupTransform>
      children:
        - !<ColorSpaceTransform> {src: Linear CIE-XYZ E, dst: Linear CIE-XYZ D65}
        - !<BuiltinTransform> {style: "UTILITY - ACES-AP0_to_CIE-XYZ-D65_BFD", direction: inverse}

  - !<ColorSpace>
    name: ACEScg
    aliases: [acescg, aces_cg, aces-cg, lin_acescg, lin_ap1_scene, lin_ap1, Linear ACEScg, ACES AP1, aces_ap1, ACES - ACEScg, "ACEScg: Linear - AP1"]
    family: ACES
    equalitygroup:
    bitdepth: 32f
    description: |
      Linear AP1 with ACES white point
    isdata: false
    from_scene_reference: !<GroupTransform>
      children:
        - !<ColorSpaceTransform> {src: Linear CIE-XYZ E, dst: Linear CIE-XYZ D65}
        - !<BuiltinTransform> {style: "UTILITY - ACES-AP1_to_CIE-XYZ-D65_BFD", direction: inverse}

  - !<ColorSpace>
    name: Linear FilmLight E-Gamut
    aliases: [Linear E-Gamut I-D65, "FilmLight: Linear - E-Gamut"]
    family: Linear
    equalitygroup:
    bitdepth: 32f
    description: |
      Linear E-Gamut with illuminant D65 white point
    isdata: false
    from_scene_reference: !<GroupTransform>
      children:
        - !<ColorSpaceTransform> {src: Linear CIE-XYZ I-E, dst: Linear CIE-XYZ I-D65}
        - !<MatrixTransform> {matrix: [1.5250528, -0.3159135, -0.1226583, 0, -0.5091526, 1.3333274, 0.1382844, 0, 0.0957153, 0.0508974, 0.7879558, 0, 0, 0, 0, 1]}

  - !<ColorSpace>
    name: Non-Color
    aliases: [raw, Generic Data, Non-Colour Data, Raw, Utility - Raw, none]
    family: Data
    description: |
        Generic data that is not color, will not apply any color transform (e.g. normal maps)
    equalitygroup:
    bitdepth: 32f
    isdata: true

  - !<ColorSpace>
    name: Luminance Compensation Rec.2020
    aliases: [Luminance Compensation BT.2020]
    family: Utilities
    equalitygroup:
    bitdepth: 32f
    description: |
      Offset the negative values in BT.2020 and compensate for luminance, ensuring there is no negative values in Rec.2020
    isdata: false
    from_scene_reference: !<GroupTransform>
      children:
        - !<ColorSpaceTransform> {src: Linear CIE-XYZ E, dst: Linear FilmLight E-Gamut}
        - !<AllocationTransform> {allocation: lg2, vars: [-12.47393, 12.5260688117]}
        - !<FileTransform> {src: luminance_compensation_bt2020.cube, interpolation: tetrahedral}
        - !<AllocationTransform> {allocation: lg2, vars: [-12.47393, 12.5260688117], direction: inverse}
        - !<ColorSpaceTransform> {src: Linear FilmLight E-Gamut, dst: Linear Rec.2020}

  - !<ColorSpace>
    name: AgX Log
    family: AgX/Log
    equalitygroup:
    bitdepth: 32f
    description: |
      Log Encoding with Chroma inset and rotation of primaries, and with 25 Stops of Dynamic Range
    isdata: false
    from_scene_reference: !<GroupTransform>
      children:
        - !<ColorSpaceTransform> {src: Linear CIE-XYZ E, dst: Luminance Compensation Rec.2020}
        # Rec.2020 generated parameters rotate = [2.13976149, -1.22827335, -3.05174246], inset = [0.32965205, 0.28051336, 0.12475368]
        - !<MatrixTransform> {matrix: [0.856627153315983, 0.0951212405381588, 0.0482516061458583, 0, 0.137318972929847, 0.761241990602591, 0.101439036467562, 0, 0.11189821299995, 0.0767994186031903, 0.811302368396859, 0, 0, 0, 0, 1]}
        - !<AllocationTransform> {allocation: lg2, vars: [-12.47393, 12.5260688117]}
    to_scene_reference: !<GroupTransform>
      children:
        - !<AllocationTransform> {allocation: lg2, vars: [-12.47393, 12.5260688117], direction: inverse}
        - !<MatrixTransform> {matrix: [0.856627153315983, 0.0951212405381588, 0.0482516061458583, 0, 0.137318972929847, 0.761241990602591, 0.101439036467562, 0, 0.11189821299995, 0.0767994186031903, 0.811302368396859, 0, 0, 0, 0, 1], direction: inverse}
        - !<ColorSpaceTransform> {src: Linear CIE-XYZ E, dst: Linear Rec.2020, direction: inverse}

looks:
  - !<Look>
    name: Film Dense
    process_space: AgX Log
    description: |
      Denser film body: thicker low-mids, deep-but-soft blacks, smooth shoulder, lower chroma.
    transform: !<GroupTransform>
      children:
        - !<GradingPrimaryTransform>
          style: log
          contrast: {rgb: [1, 1, 1], master: 1.07}
          saturation: 0.90
        - !<GradingToneTransform>
          style: log
          blacks: {rgb: [1, 1, 1], master: 1.010, start: 0.36, width: 0.48}
          highlights: {rgb: [1, 1, 1], master: 0.972, start: 0.30, pivot: 0.90}
          whites: {rgb: [1, 1, 1], master: 0.988, start: 0.36, width: 0.48}
          s_contrast: 1.02
        - !<GradingRGBCurveTransform>
          style: log
          master: {control_points: [0, 0, 0.40, 0.360, 1, 1]}
  - !<Look>
    name: Photochemical
    process_space: AgX Log
    description: |
      Film-medium shaping with obvious channel crossover, softer shoulder,
      mild print-floor contamination, and non-neutral density.
    transform: !<GroupTransform>
      children:
        - !<GradingPrimaryTransform>
          style: log
          contrast: {rgb: [1, 1, 1], master: 1.08}
          saturation: 0.86
        - !<GradingToneTransform>
          style: log
          blacks:     {rgb: [1, 1, 1], master: 0.972, start: 0.34, width: 0.52}
          highlights: {rgb: [1, 1, 1], master: 0.962, start: 0.27, pivot: 0.87}
          whites:     {rgb: [1, 1, 1], master: 0.982, start: 0.34, width: 0.52}
          s_contrast: 1.00
        - !<GradingRGBCurveTransform>
          style: log
          red:   {control_points: [0, 0, 0.20, 0.193, 0.72, 0.748, 1, 0.995]}
          green: {control_points: [0, 0, 0.20, 0.202, 0.72, 0.718, 1, 0.997]}
          blue:  {control_points: [0, 0, 0.20, 0.212, 0.72, 0.688, 1, 1]}
        - !<CDLTransform>
          {slope: [1.010, 1.000, 0.988], offset: [0.0015, 0.0005, 0.0025], power: [0.986, 1.000, 1.020], sat: 0.94}
  - !<Look>
    name: Archival Warm-Gray
    process_space: AgX Log
    description: |
      Warm-gray archival: lowest chroma, airy floor, paper/scan feel without sepia.
    transform: !<GroupTransform>
      children:
        - !<GradingPrimaryTransform>
          style: log
          contrast: {rgb: [1, 1, 1], master: 0.98}
          saturation: 0.84
        - !<GradingToneTransform>
          style: log
          blacks: {rgb: [1, 1, 1], master: 0.920, start: 0.32, width: 0.50}
          highlights: {rgb: [1, 1, 1], master: 0.968, start: 0.27, pivot: 0.88}
          whites: {rgb: [1, 1, 1], master: 0.984, start: 0.34, width: 0.50}
          s_contrast: 0.98
        - !<GradingRGBCurveTransform>
          style: log
          red: {control_points: [0, 0, 0.30, 0.302, 1, 1]}
          blue: {control_points: [0, 0, 0.30, 0.298, 1, 1]}
  # Archival Dense — more body but still lifted + muted.
  - !<Look>
    name: Carbon Plate
    process_space: AgX Log
    description: |
      Dark editorial print body: velvet blacks, compressed mids, restrained chroma, soft highlight rolloff.
    transform: !<GroupTransform>
      children:
        - !<GradingPrimaryTransform>
          style: log
          contrast: {rgb: [1, 1, 1], master: 1.10}
          saturation: 0.82
        - !<GradingToneTransform>
          style: log
          blacks: {rgb: [1, 1, 1], master: 1.010, start: 0.33, width: 0.43}
          highlights: {rgb: [1, 1, 1], master: 0.988, start: 0.27, pivot: 0.90}
          whites: {rgb: [1, 1, 1], master: 0.995, start: 0.33, width: 0.43}
          s_contrast: 1.02
        - !<GradingRGBCurveTransform>
          style: log
          master: {control_points: [0, 0, 0.45, 0.395, 1, 1]}
  - !<Look>
    name: Carbon Black
    process_space: AgX Log
    description: |
      Near-black object-photo rendering with a preserved low-mid read band and restrained chroma.
    transform: !<GroupTransform>
      children:
        - !<GradingPrimaryTransform>
          style: log
          contrast: {rgb: [1, 1, 1], master: 1.13}
