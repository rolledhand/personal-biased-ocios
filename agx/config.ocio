        - !<CDLTransform> {slope: [1.06, 1.06, 1.06], offset: [0.002, 0.0025, 0.009], power: [1.06, 1.06, 1.06], sat: 1}
        - !<CDLTransform> {slope: [1.04, 1.04, 1.04], offset: [0.0, 0.0, 0.0], power: [1.24, 1.24, 1.24], sat: 1}
