ocio_profile_version: 2.0
# Slim OpenDRT/JP2499DRT Rec.2020 config.
# Legacy DRT display outputs were pruned; LUT folders are left on disk for now.

environment:
  {}
search_path: "luts:ARRI:Canon:RWG:OpenDRT:2499DRT:Sony:BMD:ACES:TCAMv3"
strictparsing: true
luma: [0.2126, 0.7152, 0.0722]

description: RRT version ut33, custom Houdini/MoonRay Linear Rec.2020 working config

roles:
  # Keep this as the config reference if your colorspaces are authored around XYZ E.
  reference: Linear CIE-XYZ E

  # Internal scene/render linear space
  scene_linear: Linear Rec.2020
  rendering: Linear Rec.2020

  # Default color space for byte images
  default_byte: sRGB - Texture

  # Default color space for float images
  default_float: Linear Rec.2020

  # Sequencer/UI-ish default
  default_sequencer: sRGB - Texture

  # Color picker should stay display/simple, not scene wide gamut.
  color_picking: sRGB - Texture

  # Non-color data
  data: Raw

  # OCIO/ACES interop roles
  aces_interchange: ACES2065-1
  cie_xyz_d65_interchange: Linear CIE-XYZ D65

  # General app roles
  color_timing: T-LogeE - E-Gamut 2
  compositing_log: T-LogeE - E-Gamut 2
  compositing_linear: Linear Rec.2020
  default: Linear Rec.2020
  matte_paint: sRGB - Texture
  texture_paint: sRGB - Texture
  srgb_linear: Linear Rec.709

  # Substance Painter roles
  # 8/16-bit bitmap color textures are almost always authored/display-referred sRGB.
  # Floating exports are treated as scene-linear Rec.2020 only if explicitly authored that way.
  substance_3d_painter_standard_srgb: sRGB - Texture
  substance_3d_painter_bitmap_import_8bit: sRGB - Texture
  substance_3d_painter_bitmap_import_16bit: sRGB - Texture
  substance_3d_painter_bitmap_import_floating: Linear Rec.2020
  substance_3d_painter_bitmap_export_8bit: sRGB - Texture
  substance_3d_painter_bitmap_export_16bit: sRGB - Texture
  substance_3d_painter_bitmap_export_floating: Linear Rec.2020
  substance_3d_painter_substance_material: sRGB - Texture

# When using a spectral renderer, only change this if the renderer/config explicitly expects it.
# XYZ: Linear CIE-XYZ D65

file_rules:
  # --------------------------------------------------------------------------
  # 01. Path/name overrides
  # These are regex rules instead of pattern-only Basic Rules because some
  # OCIO builds reject extension: "*" with "file extension pattern is empty".
  # Keep these first so intentional naming beats generic file-extension rules.
  # --------------------------------------------------------------------------

  - !<Rule> {name: g22_rec709, regex: ".*[/_.-]g22_rec709[/_.-].*|.*[/_.-]g22_rec709\\..*|.*_g22_rec709_.*|.*_g22_rec709\\..*", colorspace: sRGB}
  - !<Rule> {name: g22_encoded_rec709, regex: ".*[/_.-]g22_encoded_rec709[/_.-].*|.*[/_.-]g22_encoded_rec709\\..*|.*_g22_encoded_rec709_.*|.*_g22_encoded_rec709\\..*", colorspace: sRGB}
  - !<Rule> {name: srgb_tx, regex: ".*[/_.-]srgb_tx[/_.-].*|.*[/_.-]srgb_tx\\..*|.*_srgb_tx_.*|.*_srgb_tx\\..*", colorspace: sRGB - Texture}
  - !<Rule> {name: srgb_texture, regex: ".*[/_.-]srgb_texture[/_.-].*|.*[/_.-]srgb_texture\\..*|.*_srgb_texture_.*|.*_srgb_texture\\..*", colorspace: sRGB - Texture}
  - !<Rule> {name: srgb_encoded_p3d65, regex: ".*[/_.-]srgb_encoded_p3d65[/_.-].*|.*[/_.-]srgb_encoded_p3d65\\..*|.*_srgb_encoded_p3d65_.*|.*_srgb_encoded_p3d65\\..*", colorspace: sRGB Encoded P3-D65}
  - !<Rule> {name: srgb_p3d65, regex: ".*[/_.-]srgb_p3d65[/_.-].*|.*[/_.-]srgb_p3d65\\..*|.*_srgb_p3d65_.*|.*_srgb_p3d65\\..*", colorspace: sRGB Encoded P3-D65}
  - !<Rule> {name: srgb_displayp3, regex: ".*[/_.-]srgb_displayp3[/_.-].*|.*[/_.-]srgb_displayp3\\..*|.*_srgb_displayp3_.*|.*_srgb_displayp3\\..*", colorspace: sRGB Encoded P3-D65}
  - !<Rule> {name: srgb_upper, regex: ".*[/_.-]sRGB[/_.-].*|.*[/_.-]sRGB\\..*|.*_sRGB_.*|.*_sRGB\\..*", colorspace: sRGB - Texture}
  - !<Rule> {name: srgb_lower, regex: ".*[/_.-]srgb[/_.-].*|.*[/_.-]srgb\\..*|.*_srgb_.*|.*_srgb\\..*", colorspace: sRGB - Texture}

  - !<Rule> {name: raw_any, regex: ".*[/_.-][rR][aA][wW][/_.-].*|.*[/_.-][rR][aA][wW]\\..*|.*_[rR][aA][wW]_.*|.*_[rR][aA][wW]\\..*", colorspace: Raw}
  - !<Rule> {name: data, regex: ".*[/_.-]data[/_.-].*|.*[/_.-]data\\..*|.*_data_.*|.*_data\\..*", colorspace: Raw}
  - !<Rule> {name: noncolor, regex: ".*[/_.-]noncolor[/_.-].*|.*[/_.-]noncolor\\..*|.*_noncolor_.*|.*_noncolor\\..*", colorspace: Raw}
  - !<Rule> {name: non_color, regex: ".*[/_.-]non_color[/_.-].*|.*[/_.-]non_color\\..*|.*_non_color_.*|.*_non_color\\..*", colorspace: Raw}
  - !<Rule> {name: utility_raw, regex: ".*[/_.-]utility_raw[/_.-].*|.*[/_.-]utility_raw\\..*|.*_utility_raw_.*|.*_utility_raw\\..*", colorspace: Raw}

  - !<Rule> {name: rec2020, regex: ".*Linear Rec\\.2020.*", colorspace: Linear Rec.2020}
  - !<Rule> {name: lin_rec2020, regex: ".*lin_rec2020.*", colorspace: Linear Rec.2020}
  - !<Rule> {name: linrec2020, regex: ".*linrec2020.*", colorspace: Linear Rec.2020}
  - !<Rule> {name: linear_rec2020, regex: ".*linear_rec2020.*", colorspace: Linear Rec.2020}
  - !<Rule> {name: bt2020, regex: ".*lin_bt2020.*", colorspace: Linear Rec.2020}
  - !<Rule> {name: linear_bt2020, regex: ".*linear_bt2020.*", colorspace: Linear Rec.2020}

  - !<Rule> {name: acescg, regex: ".*ACEScg.*", colorspace: ACEScg}
  - !<Rule> {name: acescg_lower, regex: ".*acescg.*", colorspace: ACEScg}

  - !<Rule> {name: rec709, regex: ".*Linear Rec\\.709.*", colorspace: Linear Rec.709}
  - !<Rule> {name: lin_rec709, regex: ".*lin_rec709.*", colorspace: Linear Rec.709}
  - !<Rule> {name: linrec709, regex: ".*linrec709.*", colorspace: Linear Rec.709}
  - !<Rule> {name: linear_rec709, regex: ".*linear_rec709.*", colorspace: Linear Rec.709}
  - !<Rule> {name: lin_srgb, regex: ".*lin_srgb.*", colorspace: Linear Rec.709}
  - !<Rule> {name: linear_srgb, regex: ".*linear_srgb.*", colorspace: Linear Rec.709}

  # --------------------------------------------------------------------------
  # 02. Houdini / MoonRay .tx rule
  # Keep .tx Raw because utility .tx maps are data, and basecolor .tx should
  # already be converted to Linear Rec.2020 by maketx/oiiotool before rendering.
  # This avoids OCIO applying a second transform to .tx files.
  # --------------------------------------------------------------------------

  - !<Rule> {name: tx, pattern: "*", extension: "tx", colorspace: Raw}

  # --------------------------------------------------------------------------
  # 03. PBR / utility maps that are always data
  # Keep these before generic byte-image rules.
  # Color-bearing material maps are handled separately below.
  # --------------------------------------------------------------------------

  - !<Rule> {name: PBR_Data_Maps, regex: ".*(_(Normal|normal|NRM|nrm|Norm|norm|NormalGL|normalGL|NormalDX|normalDX|Roughness|roughness|Rough|rough|Metallic|metallic|Metalness|metalness|Metal|metal|Height|height|Displacement|displacement|Disp|disp|Bump|bump|AmbientOcclusion|ambientOcclusion|Occlusion|occlusion|AO|ao|Glossiness|glossiness|Gloss|gloss|Cavity|cavity|Curvature|curvature|Thickness|thickness|Anisotropy|anisotropy|Aniso|aniso|AnisotropyLevel|anisotropyLevel|Anisotropy_Level|anisotropy_level|AnisoLevel|anisoLevel|Aniso_Level|aniso_level|AnisotropyAngle|anisotropyAngle|Anisotropy_Angle|anisotropy_angle|AnisoAngle|anisoAngle|Aniso_Angle|aniso_angle|Mask|mask|ID|id|MatID|matid|Opacity|opacity|Alpha|alpha|_nm|_nrm|_normal|_rough|_roughness|_rm|_metal|_metallic|_metalness|_mm|_height|_hm|_disp|_dm|_bump|_ao|_occ|_gloss|_gm|_cavity|_cm|_curv|_thick|_aniso|_anisotropy|_anisolevel|_aniso_level|_anisotropy_level|_anisoangle|_aniso_angle|_anisotropy_angle|_mask|_id|_opacity|_alpha|_arm|_orm|_om)).*", colorspace: Raw}

  - !<Rule> {name: PBR_Mask_Maps, regex: ".*(_(SubsurfaceMask|subsurfaceMask|Subsurface_Mask|subsurface_mask|SSSMask|sssMask|SSS_Mask|sss_mask|TransmissionMask|transmissionMask|Transmission_Mask|transmission_mask|TranslucencyMask|translucencyMask|Translucency_Mask|translucency_mask|SpecularLevel|specularLevel|Specular_Level|specular_level|SpecularAmount|specularAmount|Specular_Amount|specular_amount|CoatMask|coatMask|Coat_Mask|coat_mask|SheenMask|sheenMask|Sheen_Mask|sheen_mask)).*", colorspace: Raw}

  # --------------------------------------------------------------------------
  # 04. Color-bearing texture maps
  # Byte-image basecolor/albedo/diffuse/color maps are sRGB.
  # Ambiguous SSS/transmission/specular maps are treated as color only when
  # their names explicitly say color/colour.
  # --------------------------------------------------------------------------

  - !<Rule> {name: BaseColor_Byte_Images, regex: ".*(_(BaseColor|baseColor|basecolor|Base_Color|base_color|Albedo|albedo|Diffuse|diffuse|Diff|diff|Color|color|Colour|colour|Col|col|Base|base)).*\\.(png|jpg|jpeg|tga|tif|tiff|bmp|webp)$", colorspace: sRGB - Texture}

  - !<Rule> {name: Material_Color_Byte_Images, regex: ".*(_(SubsurfaceColor|subsurfaceColor|Subsurface_Color|subsurface_color|SSSColor|sssColor|SSS_Color|sss_color|TransmissionColor|transmissionColor|Transmission_Color|transmission_color|TranslucencyColor|translucencyColor|Translucency_Color|translucency_color|SpecularColor|specularColor|Specular_Color|specular_color|CoatColor|coatColor|Coat_Color|coat_color|SheenColor|sheenColor|Sheen_Color|sheen_color)).*\\.(png|jpg|jpeg|tga|tif|tiff|bmp|webp)$", colorspace: sRGB - Texture}

  # --------------------------------------------------------------------------
  # 05. USDZ embedded texture rules
  # Kept before generic byte-image rules so packed textures keep their intent.
  # --------------------------------------------------------------------------

  - !<Rule> {name: __usdz_jpg, colorspace: sRGB - Texture, regex: ".*[uu][ss][dd][zz]\\[.*[jj][pp][gg]\\]"}
  - !<Rule> {name: __usdz_jpeg, colorspace: sRGB - Texture, regex: ".*[uu][ss][dd][zz]\\[.*[jj][pp][ee][gg]\\]"}
  - !<Rule> {name: __usdz_tga, colorspace: sRGB - Texture, regex: ".*[uu][ss][dd][zz]\\[.*[tt][gg][aa]\\]"}
  - !<Rule> {name: __usdz_png, colorspace: sRGB - Texture, regex: ".*[uu][ss][dd][zz]\\[.*[pp][nn][gg]\\]"}
  - !<Rule> {name: __usdz_tif, colorspace: sRGB - Texture, regex: ".*[uu][ss][dd][zz]\\[.*[tt][ii][ff]\\]"}
  - !<Rule> {name: __usdz_tiff, colorspace: sRGB - Texture, regex: ".*[uu][ss][dd][zz]\\[.*[tt][ii][ff][ff]\\]"}
  - !<Rule> {name: __usdz_exr, colorspace: Linear Rec.2020, regex: ".*[uu][ss][dd][zz]\\[.*[ee][xx][rr]\\]"}

  # --------------------------------------------------------------------------
  # 06. Standard byte image formats
  # Generic fallback. Utility maps should already be caught above.
  # --------------------------------------------------------------------------

  - !<Rule> {name: jpg, pattern: "*", extension: "jpg", colorspace: sRGB - Texture}
  - !<Rule> {name: jpeg, pattern: "*", extension: "jpeg", colorspace: sRGB - Texture}
  - !<Rule> {name: tga, pattern: "*", extension: "tga", colorspace: sRGB - Texture}
  - !<Rule> {name: png, pattern: "*", extension: "png", colorspace: sRGB - Texture}
  - !<Rule> {name: tif, pattern: "*", extension: "tif", colorspace: sRGB - Texture}
  - !<Rule> {name: tiff, pattern: "*", extension: "tiff", colorspace: sRGB - Texture}
  - !<Rule> {name: bmp, pattern: "*", extension: "bmp", colorspace: sRGB - Texture}
  - !<Rule> {name: webp, pattern: "*", extension: "webp", colorspace: sRGB - Texture}

  # --------------------------------------------------------------------------
  # 07. Floating / HDR formats
  # EXR defaults to Linear Rec.2020 in this config unless the filename/path
  # explicitly says ACEScg, Linear Rec.2020, Linear Rec.709, Raw, etc. above.
  # HDRIs stay Linear Rec.709 unless explicitly overridden above.
  # --------------------------------------------------------------------------

  - !<Rule> {name: OpenEXR, pattern: "*", extension: "exr", colorspace: Linear Rec.2020}
  - !<Rule> {name: hdr, pattern: "*", extension: "hdr", colorspace: Linear Rec.709}

  # --------------------------------------------------------------------------
  # 08. OCIO color-space-name path search and final fallback
  # --------------------------------------------------------------------------

  - !<Rule> {name: ColorSpaceNamePathSearch}
  - !<Rule> {name: Default, colorspace: Linear Rec.2020}

displays: 
  sRGB:
    - !<View> {name: OpenDRT Bleached, colorspace: OpenDRT Bleached sRGB Display}
    - !<View> {name: OpenDRT Bleached - Negative Print, colorspace: OpenDRT Bleached - Negative Print sRGB Display}
    - !<View> {name: OpenDRT Bleached - Oxide Residue, colorspace: OpenDRT Bleached - Oxide Residue sRGB Display}
    - !<View> {name: OpenDRT Gentle Touch, colorspace: OpenDRT Gentle Touch sRGB Display}
    - !<View> {name: OpenDRT Gentle Touch - Negative Print, colorspace: OpenDRT Gentle Touch - Negative Print sRGB Display}
    - !<View> {name: OpenDRT Flawed Emulsion, colorspace: OpenDRT Flawed Emulsion sRGB Display}
    - !<View> {name: OpenDRT Flawed Emulsion - Editorial Depth, colorspace: OpenDRT Flawed Emulsion - Editorial Depth sRGB Display}
    - !<View> {name: OpenDRT Flawed Emulsion - Chemical Drift, colorspace: OpenDRT Flawed Emulsion - Chemical Drift sRGB Display}
    - !<View> {name: OpenDRT Shifted Crisp, colorspace: OpenDRT Shifted Crisp sRGB Display}
    - !<View> {name: OpenDRT Standard, colorspace: OpenDRT Standard sRGB Display}
    - !<View> {name: JP2499DRT, colorspace: 2499DRT Base sRGB}
    - !<View> {name: JP2499DRT - Editorial Split, colorspace: 2499DRT Base sRGB, looks: "JP2499DRT - Editorial Split"}
    - !<View> {name: JP2499DRT - Hard Contrast, colorspace: 2499DRT Base sRGB, looks: "JP2499DRT - Hard Contrast"}
    - !<View> {name: JP2499DRT - Photochemical, colorspace: 2499DRT Base sRGB, looks: "JP2499DRT - Photochemical"}
    - !<View> {name: JP2499DRT - Chemical Drift, colorspace: 2499DRT Base sRGB, looks: "JP2499DRT - Chemical Drift"}
    - !<View> {name: JP2499DRT - Tarnished Print, colorspace: 2499DRT Base sRGB, looks: "JP2499DRT - Tarnished Print"}
    - !<View> {name: JP2499DRT - Graphite Matte, colorspace: 2499DRT Base sRGB, looks: "JP2499DRT - Graphite Matte"}
    - !<View> {name: JP2499DRT - Soot, colorspace: 2499DRT Base sRGB, looks: "JP2499DRT - Soot"}
    - !<View> {name: JP2499DRT - Carbon Plate, colorspace: 2499DRT Base sRGB, looks: "JP2499DRT - Carbon Plate"}
    - !<View> {name: JP2499DRT - Carbon Black, colorspace: 2499DRT Base sRGB, looks: "JP2499DRT - Carbon Black"}
    - !<View> {name: JP2499DRT - Blue Carbon Print, colorspace: 2499DRT Base sRGB, looks: "JP2499DRT - Blue Carbon Print"}
    - !<View> {name: JP2499DRT - Funeral Bronze, colorspace: 2499DRT Base sRGB, looks: "JP2499DRT - Funeral Bronze"}
    - !<View> {name: JP2499DRT - Phoenix Drift, colorspace: 2499DRT Base sRGB, looks: "JP2499DRT - Phoenix Drift"}
    - !<View> {name: None, colorspace: Raw}
  Display P3:
    - !<View> {name: OpenDRT Bleached, colorspace: OpenDRT Bleached Display P3}
    - !<View> {name: OpenDRT Bleached - Negative Print, colorspace: OpenDRT Bleached - Negative Print Display P3}
    - !<View> {name: OpenDRT Bleached - Oxide Residue, colorspace: OpenDRT Bleached - Oxide Residue Display P3}
    - !<View> {name: OpenDRT Gentle Touch, colorspace: OpenDRT Gentle Touch Display P3}
    - !<View> {name: OpenDRT Gentle Touch - Negative Print, colorspace: OpenDRT Gentle Touch - Negative Print Display P3}
    - !<View> {name: OpenDRT Flawed Emulsion, colorspace: OpenDRT Flawed Emulsion Display P3}
    - !<View> {name: OpenDRT Flawed Emulsion - Editorial Depth, colorspace: OpenDRT Flawed Emulsion - Editorial Depth Display P3}
    - !<View> {name: OpenDRT Flawed Emulsion - Chemical Drift, colorspace: OpenDRT Flawed Emulsion - Chemical Drift Display P3}
    - !<View> {name: OpenDRT Shifted Crisp, colorspace: OpenDRT Shifted Crisp Display P3}
    - !<View> {name: OpenDRT Standard, colorspace: OpenDRT Standard Display P3}
    - !<View> {name: JP2499DRT, colorspace: 2499DRT Base Display P3}
    - !<View> {name: JP2499DRT - Editorial Split, colorspace: 2499DRT Base Display P3, looks: "JP2499DRT - Editorial Split"}
    - !<View> {name: JP2499DRT - Hard Contrast, colorspace: 2499DRT Base Display P3, looks: "JP2499DRT - Hard Contrast"}
    - !<View> {name: JP2499DRT - Photochemical, colorspace: 2499DRT Base Display P3, looks: "JP2499DRT - Photochemical"}
    - !<View> {name: JP2499DRT - Chemical Drift, colorspace: 2499DRT Base Display P3, looks: "JP2499DRT - Chemical Drift"}
    - !<View> {name: JP2499DRT - Tarnished Print, colorspace: 2499DRT Base Display P3, looks: "JP2499DRT - Tarnished Print"}
    - !<View> {name: JP2499DRT - Graphite Matte, colorspace: 2499DRT Base Display P3, looks: "JP2499DRT - Graphite Matte"}
    - !<View> {name: JP2499DRT - Soot, colorspace: 2499DRT Base Display P3, looks: "JP2499DRT - Soot"}
    - !<View> {name: JP2499DRT - Carbon Plate, colorspace: 2499DRT Base Display P3, looks: "JP2499DRT - Carbon Plate"}
    - !<View> {name: JP2499DRT - Carbon Black, colorspace: 2499DRT Base Display P3, looks: "JP2499DRT - Carbon Black"}
    - !<View> {name: JP2499DRT - Blue Carbon Print, colorspace: 2499DRT Base Display P3, looks: "JP2499DRT - Blue Carbon Print"}
    - !<View> {name: JP2499DRT - Funeral Bronze, colorspace: 2499DRT Base Display P3, looks: "JP2499DRT - Funeral Bronze"}
    - !<View> {name: JP2499DRT - Phoenix Drift, colorspace: 2499DRT Base Display P3, looks: "JP2499DRT - Phoenix Drift"}
    - !<View> {name: None, colorspace: Raw}
  Rec.1886:
    - !<View> {name: OpenDRT Bleached, colorspace: OpenDRT Bleached Rec.1886}
    - !<View> {name: OpenDRT Bleached - Negative Print, colorspace: OpenDRT Bleached - Negative Print Rec.1886}
    - !<View> {name: OpenDRT Bleached - Oxide Residue, colorspace: OpenDRT Bleached - Oxide Residue Rec.1886}
    - !<View> {name: OpenDRT Gentle Touch, colorspace: OpenDRT Gentle Touch Rec.1886}
    - !<View> {name: OpenDRT Gentle Touch - Negative Print, colorspace: OpenDRT Gentle Touch - Negative Print Rec.1886}
    - !<View> {name: OpenDRT Flawed Emulsion, colorspace: OpenDRT Flawed Emulsion Rec.1886}
    - !<View> {name: OpenDRT Flawed Emulsion - Editorial Depth, colorspace: OpenDRT Flawed Emulsion - Editorial Depth Rec.1886}
    - !<View> {name: OpenDRT Flawed Emulsion - Chemical Drift, colorspace: OpenDRT Flawed Emulsion - Chemical Drift Rec.1886}
    - !<View> {name: OpenDRT Shifted Crisp, colorspace: OpenDRT Shifted Crisp Rec.1886}
    - !<View> {name: OpenDRT Standard, colorspace: OpenDRT Standard Rec.1886}
    - !<View> {name: JP2499DRT, colorspace: 2499DRT Base Rec.1886}
    - !<View> {name: JP2499DRT - Editorial Split, colorspace: 2499DRT Base Rec.1886, looks: "JP2499DRT - Editorial Split"}
    - !<View> {name: JP2499DRT - Hard Contrast, colorspace: 2499DRT Base Rec.1886, looks: "JP2499DRT - Hard Contrast"}
    - !<View> {name: JP2499DRT - Photochemical, colorspace: 2499DRT Base Rec.1886, looks: "JP2499DRT - Photochemical"}
    - !<View> {name: JP2499DRT - Chemical Drift, colorspace: 2499DRT Base Rec.1886, looks: "JP2499DRT - Chemical Drift"}
    - !<View> {name: JP2499DRT - Tarnished Print, colorspace: 2499DRT Base Rec.1886, looks: "JP2499DRT - Tarnished Print"}
    - !<View> {name: JP2499DRT - Graphite Matte, colorspace: 2499DRT Base Rec.1886, looks: "JP2499DRT - Graphite Matte"}
    - !<View> {name: JP2499DRT - Soot, colorspace: 2499DRT Base Rec.1886, looks: "JP2499DRT - Soot"}
    - !<View> {name: JP2499DRT - Carbon Plate, colorspace: 2499DRT Base Rec.1886, looks: "JP2499DRT - Carbon Plate"}
    - !<View> {name: JP2499DRT - Carbon Black, colorspace: 2499DRT Base Rec.1886, looks: "JP2499DRT - Carbon Black"}
    - !<View> {name: JP2499DRT - Blue Carbon Print, colorspace: 2499DRT Base Rec.1886, looks: "JP2499DRT - Blue Carbon Print"}
    - !<View> {name: JP2499DRT - Funeral Bronze, colorspace: 2499DRT Base Rec.1886, looks: "JP2499DRT - Funeral Bronze"}
    - !<View> {name: JP2499DRT - Phoenix Drift, colorspace: 2499DRT Base Rec.1886, looks: "JP2499DRT - Phoenix Drift"}
    - !<View> {name: None, colorspace: Raw}
  Log:
    - !<View> {name: JP2499 Log, colorspace: 2499DRT Log (2499)}
    - !<View> {name: Filmlight T-LogE - E-Gamut 2, colorspace: T-LogeE - E-Gamut 2}
    - !<View> {name: ACEScc, colorspace: ACEScc}
    - !<View> {name: ACEScct, colorspace: ACEScct}
    - !<View> {name: None, colorspace: Raw}

active_displays: [sRGB, Display P3, Rec.1886, Log]

active_views: [OpenDRT Bleached, OpenDRT Bleached - Negative Print, OpenDRT Bleached - Oxide Residue, OpenDRT Gentle Touch, OpenDRT Gentle Touch - Negative Print, OpenDRT Flawed Emulsion, OpenDRT Flawed Emulsion - Editorial Depth, OpenDRT Flawed Emulsion - Chemical Drift, OpenDRT Shifted Crisp, OpenDRT Standard, JP2499DRT, JP2499DRT - Editorial Split, JP2499DRT - Hard Contrast, JP2499DRT - Photochemical, JP2499DRT - Chemical Drift, JP2499DRT - Tarnished Print, JP2499DRT - Graphite Matte, JP2499DRT - Soot, JP2499DRT - Carbon Plate, JP2499DRT - Carbon Black, JP2499DRT - Blue Carbon Print, JP2499DRT - Funeral Bronze, JP2499DRT - Phoenix Drift, JP2499 Log, Filmlight T-LogE - E-Gamut 2, ACEScc, ACEScct, None]
#--------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
# Legacy DRT/display-output colorspaces were intentionally pruned from this slim OpenDRT/JP2499DRT config.
# Camera/input, ACES interchange, texture/file-rule, OpenDRT, and JP2499DRT spaces remain available.

colorspaces:
#Linear Stuff

  - !<ColorSpace> #Linear CIE-XYZ E
    name: Linear CIE-XYZ E
    aliases: ["FilmLight: Linear - XYZ", Linear CIE-XYZ I-E]
    family: Chromaticity
    equalitygroup:
    bitdepth: 32f
    description: |
      1931 CIE XYZ standard with assumed illuminant E white point
    isdata: false

  - !<ColorSpace> #Linear CIE-XYZ D65
    name: Linear CIE-XYZ D65
    aliases: [cie_xyz_d65, CIE-XYZ-D65, XYZ, Linear CIE-XYZ I-D65]
    family: Chromaticity
    equalitygroup:
    bitdepth: 32f
    description: |
      1931 CIE XYZ with adapted illuminant D65 white point
    isdata: false
    from_scene_reference: !<FileTransform> {src: xyz_E_to_D65.spimtx, interpolation: linear}

  - !<ColorSpace> #Linear CIE-XYZ DCI
    name: Linear CIE-XYZ DCI
    aliases: [cie_xyz_dci, CIE-XYZ-DCI, Linear CIE-XYZ DCI]
    family: Chromaticity
    equalitygroup:
    bitdepth: 32f
    description: |
      1931 CIE XYZ with adapted DCI illuminant via Bradford
