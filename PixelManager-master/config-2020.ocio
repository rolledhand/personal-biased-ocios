        - !<ExponentWithLinearTransform> {gamma: 2.4, offset: 0.055, direction: inverse}

  - !<ColorSpace> #sRGB Encoded P3-D65
    name: sRGB Encoded P3-D65
    aliases: [srgb_encoded_p3d65, srgb_p3d65, srgb_displayp3, srgb_p3d65_scene, sRGB Encoded P3-D65 - Texture, srgb_encoded_p3d65_tx]
    family: Utility
    equalitygroup:
    bitdepth: 32f
    description: |
      Apple's Display P3 primaries with sRGB compound (piece-wise) encoding transfer function
    isdata: false
    categories: [file-io, texture]
    encoding: sdr-video
    from_scene_reference: !<GroupTransform>
      children:
        - !<ColorSpaceTransform> {src: Linear CIE-XYZ E, dst: Linear DCI-P3 D65}
        - !<ExponentWithLinearTransform> {gamma: 2.4, offset: 0.055, direction: inverse}

  - !<ColorSpace> #Display P3 EOTF 2.2
    name: Display P3 EOTF 2.2
    aliases: [Display P3, Display P3 2.2, Display P3 I-D65, P3-D65 - Display, p3_d65_display, p3d65_display, AppleP3 sRGB OETF]
    family: Utility
    equalitygroup:
    bitdepth: 32f
    description: |
      Apple's Display P3 with Pure 2.2 encoding transfer function, common on Mac devices
    isdata: false
    from_scene_reference: !<GroupTransform>
      children:
        - !<ColorSpaceTransform> {src: Linear CIE-XYZ E, dst: Linear DCI-P3 D65}
        - !<ExponentTransform> {value: 2.2, direction: inverse}

  - !<ColorSpace> #AdobeRGB Legacy
    name: AdobeRGB Legacy
    aliases: [AdobeRGB Piecewise 2.2, Legacy AdobeRGB]
    family: Display
    equalitygroup:
    bitdepth: 32f
    description: |
      AdobeRGB 1998 piece-wise function
    isdata: false
    from_scene_reference: !<GroupTransform>
      children:
        - !<ColorSpaceTransform> {src: Linear CIE-XYZ E, dst: Linear Adobe RGB (1998)}
        - !<ExponentWithLinearTransform> {gamma: 2.4, offset: 0.055, direction: inverse}

  - !<ColorSpace> #AdobeRGB EOTF 2.2
    name: AdobeRGB EOTF 2.2
    aliases: []
    family: Display
    equalitygroup:
    bitdepth: 32f
    description: |
      AdobeRGB 1998 2.2 pure EOTF.
    isdata: false
    from_scene_reference: !<GroupTransform>
      children:
        - !<ColorSpaceTransform> {src: Linear CIE-XYZ E, dst: Linear Adobe RGB (1998)}
        - !<ExponentTransform> {value: 2.2, direction: inverse}

  - !<ColorSpace> #DCI-P3 2.6
    name: DCI-P3 2.6
    aliases: []
    family: Display
    equalitygroup:
    bitdepth: 32f
    description: |
      DCI-P3 cinema standard display view.
