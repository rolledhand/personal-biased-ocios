        - !<ExponentTransform> {value: 2.6, direction: inverse}

  - !<ColorSpace> #DCI-P3 D65 2.6
    name: DCI-P3 D65 2.6
    aliases: []
    family: Display
    equalitygroup:
    bitdepth: 32f
    description: |
      DCI-P3 D65 standard display view.
    isdata: false
    from_scene_reference: !<GroupTransform>
      children:
        - !<ColorSpaceTransform> {src: Linear CIE-XYZ E, dst: Linear DCI-P3 D65}
        - !<ExponentTransform> {value: 2.6, direction: inverse}

  - !<ColorSpace> #Rec.2020
    name: Rec.2020
    aliases: [BT.2020, BT.2020 2.4, BT.2020 I-D65, Rec.1886 / Rec.2020 Video - Display, rec1886_rec2020_video_display, Rec.1886 Rec.2020 - Display, rec1886_rec2020_display, "Rec1886: 2.4 Gamma - Rec.2020"]
    family: Display
    equalitygroup:
    bitdepth: 32f
    description: |
      BT.2020 2.4 Exponent EOTF Display
    isdata: false
    from_scene_reference: !<GroupTransform>
      children:
        - !<ColorSpaceTransform> {src: Linear CIE-XYZ E, dst: Linear Rec.2020}
        - !<ExponentTransform> {value: 2.4, direction: inverse}

  - !<ColorSpace> #Rec.2100-PQ
    name: Rec.2100-PQ
    aliases: [Rec.2100-PQ - Display, rec2100_pq_display, BT2100, ST-2084, Rec.2100]
    family: Display
    equalitygroup:
    bitdepth: 32f
    description: |
      BT.2100 PQ Exponent Display
    isdata: false
    from_scene_reference: !<GroupTransform>
      children:
        - !<ColorSpaceTransform> {src: Linear CIE-XYZ E, dst: Linear Rec.2020}
        - !<BuiltinTransform> {style: CURVE - LINEAR_to_ST-2084}

  - !<ColorSpace> #Rec.2100-PQ 1000 nits limited
    name: Rec.2100-PQ 1000 nits limited
    aliases: [Rec.2100(1000nit Limit)]
    family: Display
    equalitygroup: ""
    bitdepth: 32f
    description: BT.2100-ST.2084 1000 nits limited display
    isdata: false
    allocation: uniform
    from_scene_reference: !<GroupTransform>
      children:
        - !<ColorSpaceTransform> {src: Linear CIE-XYZ E, dst: Linear Rec.2020}
        - !<RangeTransform> {max_in_value: 10, max_out_value: 10}
        - !<BuiltinTransform> {style: CURVE - LINEAR_to_ST-2084}
    to_scene_reference: !<GroupTransform>
      children:
        - !<BuiltinTransform> {style: CURVE - LINEAR_to_ST-2084, direction: inverse}
        - !<ColorSpaceTransform> {src: Linear CIE-XYZ E, dst: Linear Rec.2020, direction: inverse}

  - !<ColorSpace> #Rec.2100-HLG
    name: Rec.2100-HLG
    aliases: [rec2100_hlg_display, Rec.2100-HLG - Display, BT.2100-HLG]
    family: Display
    equalitygroup: ""
    bitdepth: 32f
    description: BT.2100-HLG 1000 nit Display
    isdata: false
    allocation: uniform
    from_scene_reference: !<GroupTransform>
      children:
        - !<ColorSpaceTransform> {src: Linear CIE-XYZ E, dst: Linear CIE-XYZ D65}
        - !<BuiltinTransform> {style: DISPLAY - CIE-XYZ-D65_to_REC.2100-HLG-1000nit}

  - !<ColorSpace> #BT.2020 2.4 I-E
    name: BT.2020 2.4 I-E
    aliases: []
    family: Display
    equalitygroup: ""
    bitdepth: unknown
    description: BT.2020 2.4 Exponent EOTF Display with I-E white point
    isdata: false
    allocation: uniform
    from_scene_reference: !<GroupTransform>
      children:
        - !<ColorSpaceTransform> {src: Linear CIE-XYZ I-E, dst: Linear BT.2020 I-E}
        - !<ExponentTransform> {value: 2.4, direction: inverse}

#Utility Stuff

  - !<ColorSpace> #Raw / Non-Color
    name: Raw
    aliases: [Generic Data, Non-Colour Data, Non-Color, raw, Utility - Raw, none, Passthrough]
    family: Utility
    description: |
        Generic data that is not color, will not apply any color transform (e.g. normal maps)
    equalitygroup:
    bitdepth: 32f
    isdata: true

looks:

  - !<Look> #JP2499DRT - Editorial Split
    name: JP2499DRT - Editorial Split
    process_space: 2499DRT Log (2499)
    description: Editorial warm-high / cool-low split with restrained magnitude.
    transform: !<GroupTransform>
      children:
        - !<GradingPrimaryTransform>
          style: log
          contrast: {rgb: [1, 1, 1], master: 1.06}
          saturation: 0.92
        - !<GradingToneTransform>
          style: log
          blacks:     {rgb: [1, 1, 1], master: 1.006, start: 0.33, width: 0.44}
          highlights: {rgb: [1, 1, 1], master: 0.992, start: 0.27, pivot: 0.91}
          whites:     {rgb: [1, 1, 1], master: 1.000, start: 0.33, width: 0.44}
          s_contrast: 1.01
        - !<GradingRGBCurveTransform>
          style: log
          red: {control_points: [0, 0, 0.28, 0.275, 1, 1]}
          blue: {control_points: [0, 0, 0.28, 0.285, 1, 1]}
          green: {control_points: [0, 0, 0.28, 0.281, 1, 1]}
        - !<GradingRGBCurveTransform>
          style: log
          red: {control_points: [0, 0, 0.78, 0.784, 1, 1]}
          blue: {control_points: [0, 0, 0.78, 0.776, 1, 1]}
  - !<Look> #JP2499DRT - Hard Contrast
    name: JP2499DRT - Hard Contrast
    process_space: 2499DRT Log (2499)
    description: Stronger AgX editorial contrast with deeper blacks, moderated chroma, and clean highlight rolloff.
    transform: !<GroupTransform>
      children:
        - !<GradingPrimaryTransform>
          style: log
          contrast: {rgb: [1, 1, 1], master: 1.18}
          saturation: 0.76
        - !<GradingToneTransform>
          style: log
          blacks: {rgb: [1, 1, 1], master: 1.045, start: 0.32, width: 0.40}
          highlights: {rgb: [1, 1, 1], master: 0.986, start: 0.27, pivot: 0.90}
          whites: {rgb: [1, 1, 1], master: 0.992, start: 0.33, width: 0.42}
          s_contrast: 1.04
        - !<GradingRGBCurveTransform>
          style: log
          master: {control_points: [0, 0, 0.12, 0.075, 0.42, 0.375, 0.82, 0.835, 1, 1]}

  - !<Look> #JP2499DRT - Photochemical
    name: JP2499DRT - Photochemical
    process_space: 2499DRT Log (2499)
    description: Film-medium shaping with channel crossover, softer shoulder, print-floor contamination, and non-neutral density.
    transform: !<GroupTransform>
      children:
        - !<GradingPrimaryTransform>
          style: log
          contrast: {rgb: [1, 1, 1], master: 1.08}
          saturation: 0.86
        - !<GradingToneTransform>
          style: log
          blacks:     {rgb: [1, 1, 1], master: 0.972, start: 0.34, width: 0.52}
          highlights: {rgb: [1, 1, 1], master: 0.962, start: 0.27, pivot: 0.87}
          whites:     {rgb: [1, 1, 1], master: 0.982, start: 0.34, width: 0.52}
          s_contrast: 1.00
        - !<GradingRGBCurveTransform>
          style: log
          red:   {control_points: [0, 0, 0.20, 0.193, 0.72, 0.748, 1, 0.995]}
          green: {control_points: [0, 0, 0.20, 0.202, 0.72, 0.718, 1, 0.997]}
          blue:  {control_points: [0, 0, 0.20, 0.212, 0.72, 0.688, 1, 1]}
        - !<CDLTransform>
          {slope: [1.010, 1.000, 0.988], offset: [0.0015, 0.0005, 0.0025], power: [0.986, 1.000, 1.020], sat: 0.94}
  - !<Look> #JP2499DRT - Chemical Drift
    name: JP2499DRT - Chemical Drift
    process_space: 2499DRT Log (2499)
    description: Broken photochemical drift with dirty yellow-green lows, weak cyan-blue whites, and compressed shoulder.
    transform: !<GroupTransform>
      children:
        - !<GradingPrimaryTransform>
          style: log
          contrast: {rgb: [1, 1, 1], master: 1.00}
          saturation: 0.78
