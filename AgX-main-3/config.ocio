# OpenColorIO configuration file for Blender
#
# ACEScg and ACES2065-1 spaces using OpenColorIO's BuiltinTransform
#
# Filmic Dynamic Range LUT configuration crafted by Troy James Sobotka with
# special thanks and feedback from Guillermo, Claudio Rocha, Bassam Kurdali,
# Eugenio Pignataro, Henri Hebeisen, Jason Clarke, Haarm-Peter Duiker, Thomas
# Mansencal, and Timothy Lottes.
#
# Based on original AgX by Troy Sobotka: https://github.com/sobotka/AgX https://github.com/sobotka/SB2383-Configuration-Generation
# Further Developed by Zijun Eary Zhou法纤净, Mark Faderbauer, and Sakari Kapanen
# Repository for this version: https://github.com/EaryChow/AgX
#
# See ocio-license.txt for details.

ocio_profile_version: 2.4

search_path: "luts:filmic"
strictparsing: true
luma: [0.2126, 0.7152, 0.0722]

description: RRT version ut33

roles:
  reference: Linear CIE-XYZ E

  # Internal scene linear space
  scene_linear: Linear Rec.2020
  rendering: Linear Rec.2020

  # Default color space for byte image
  default_byte: sRGB - Texture

  # Default color space for float images
  default_float: Linear Rec.2020

  # Default color space sequencer is working in
  default_sequencer: sRGB - Texture

  # Distribution of colors in color picker
  color_picking: sRGB - Texture

  # Non-color data
  data: Raw

  # For interop between configs, and to determine XYZ for rendering
  aces_interchange: ACES2065-1
  cie_xyz_d65_interchange: CIE-XYZ-D65

  # Specified by OCIO, not used in Blender
  color_timing: AgX Log
  compositing_log: AgX Log
  default: Linear Rec.2020
  matte_paint: Linear Rec.2020
  texture_paint: sRGB - Texture

file_rules:
  - !<Rule> {name: srgb_tx, colorspace: sRGB - Texture, pattern: "*srgb_tx*", extension: "*"}
  - !<Rule> {name: srgb_texture, colorspace: sRGB - Texture, pattern: "*srgb_texture*", extension: "*"}
  - !<Rule> {name: ACEScg, colorspace: ACEScg, pattern: "*ACEScg*", extension: "*"}
  - !<Rule> {name: lin_rec709, colorspace: Linear Rec.709 (sRGB), pattern: "*lin_rec709*", extension: "*"}
  - !<Rule> {name: lin_srgb, colorspace: Linear Rec.709 (sRGB), pattern: "*lin_srgb*", extension: "*"}
  - !<Rule> {name: lin_rec2020, colorspace: Linear Rec.2020, pattern: "*lin_rec2020*", extension: "*"}
  - !<Rule> {name: lin_bt2020, colorspace: Linear Rec.2020, pattern: "*lin_bt2020*", extension: "*"}
  - !<Rule> {name: jpg, colorspace: sRGB - Texture, pattern: "*", extension: jpg}
  - !<Rule> {name: jpeg, colorspace: sRGB - Texture, pattern: "*", extension: jpeg}
  - !<Rule> {name: tga, colorspace: sRGB - Texture, pattern: "*", extension: tga}
  - !<Rule> {name: png, colorspace: sRGB - Texture, pattern: "*", extension: png}
  - !<Rule> {name: tif, colorspace: sRGB - Texture, pattern: "*", extension: tif}
  - !<Rule> {name: tiff, colorspace: sRGB - Texture, pattern: "*", extension: tiff}
  - !<Rule> {name: exr, colorspace: Linear Rec.2020, pattern: "*", extension: exr}
  - !<Rule> {name: __usdz_jpg, colorspace: sRGB - Texture, regex: ".[uu][ss][dd][zz]\\[.*[jj][pp][gg]\\]"}
  - !<Rule> {name: __usdz_jpeg, colorspace: sRGB - Texture, regex: ".[uu][ss][dd][zz]\\[.*[jj][pp][ee][gg]\\]"}
  - !<Rule> {name: __usdz_tga, colorspace: sRGB - Texture, regex: ".[uu][ss][dd][zz]\\[.*[tt][gg][aa]\\]"}
  - !<Rule> {name: __usdz_png, colorspace: sRGB - Texture, regex: ".[uu][ss][dd][zz]\\[.*[pp][nn][gg]\\]"}
  - !<Rule> {name: __usdz_tif, colorspace: sRGB - Texture, regex: ".[uu][ss][dd][zz]\\[.*[tt][ii][ff]\\]"}
  - !<Rule> {name: __usdz_tiff, colorspace: sRGB - Texture, regex: ".[uu][ss][dd][zz]\\[.*[tt][ii][ff][ff]\\]"}
  - !<Rule> {name: __usdz_exr, colorspace: Linear Rec.2020, regex: ".[uu][ss][dd][zz]\\[.*[ee][xx][rr]\\]"}
  - !<Rule> {name: Default, colorspace: Linear Rec.2020}

displays:
  sRGB - Display:
    - !<View> {name: AgX, view_transform: AgX Base Rec.1886, display_colorspace: sRGB - Display}
    - !<View> {name: AgX - Base, view_transform: AgX Base Rec.1886, display_colorspace: sRGB - Display}
    - !<View> {name: AgX - Editorial Soft, view_transform: AgX Base Rec.1886, display_colorspace: sRGB - Display, looks: Editorial Soft}
    - !<View> {name: AgX - Editorial Split, view_transform: AgX Base Rec.1886, display_colorspace: sRGB - Display, looks: Editorial Split}
    - !<View> {name: AgX - Hard Contrast, view_transform: AgX Base Rec.1886, display_colorspace: sRGB - Display, looks: Hard Contrast}
    - !<View> {name: AgX - Monochrome Warm, view_transform: AgX Base Rec.1886, display_colorspace: sRGB - Display, looks: Monochrome Warm}
    - !<View> {name: AgX - Ash Relic, view_transform: AgX Base Rec.1886, display_colorspace: sRGB - Display, looks: Ash Relic}
