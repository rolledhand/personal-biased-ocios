    - !<View> {name: AgX - Old Varnish, view_transform: AgX Base Rec.1886, display_colorspace: sRGB - Display, looks: Old Varnish}
    - !<View> {name: AgX - Soot, view_transform: AgX Base Rec.1886, display_colorspace: sRGB - Display, looks: Soot}
    - !<View> {name: AgX - Film Dense, view_transform: AgX Base Rec.1886, display_colorspace: sRGB - Display, looks: Film Dense}
    - !<View> {name: AgX - Photochemical, view_transform: AgX Base Rec.1886, display_colorspace: sRGB - Display, looks: Photochemical}
    - !<View> {name: AgX - Vitrine, view_transform: AgX Base Rec.1886, display_colorspace: sRGB - Display, looks: Vitrine}
