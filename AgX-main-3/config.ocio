    - !<View> {name: AgX - Lead Silver, view_transform: AgX Base Rec.1886, display_colorspace: sRGB - Display, looks: Lead Silver}
    - !<View> {name: AgX - Sepulchre, view_transform: AgX Base Rec.1886, display_colorspace: sRGB - Display, looks: Sepulchre}
    - !<View> {name: AgX - Charcoal Warm, view_transform: AgX Base Rec.1886, display_colorspace: sRGB - Display, looks: Charcoal Warm}
    - !<View> {name: AgX - Dead Umber, view_transform: AgX Base Rec.1886, display_colorspace: sRGB - Display, looks: Dead Umber}
    - !<View> {name: AgX - Verdigris Shadow, view_transform: AgX Base Rec.1886, display_colorspace: sRGB - Display, looks: Verdigris Shadow}
    - !<View> {name: AgX - Tarnished Print, view_transform: AgX Base Rec.1886, display_colorspace: sRGB - Display, looks: Tarnished Print}
    - !<View> {name: AgX - Negative Dust, view_transform: AgX Base Rec.1886, display_colorspace: sRGB - Display, looks: Negative Dust}
    - !<View> {name: AgX - Chapel, view_transform: AgX Base Rec.1886, display_colorspace: sRGB - Display, looks: Chapel}
